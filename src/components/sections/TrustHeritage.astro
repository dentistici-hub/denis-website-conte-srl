---
/**
 * Conte srl — Trust-heritage block (bespoke)
 * Editorial heritage block with KenBurnsImage as scaled-and-darkened
 * background per copy.md §9 / motion-plan §2.
 *
 * Centro Tecnico Tachigrafi badge gets a single ClipMaskReveal from the left
 * — reads as "official document arriving" / a stamp being applied.
 */
import KenBurnsImage from '@shared/motion-primitives/KenBurnsImage.astro';
import ClipMaskReveal from '@shared/motion-primitives/ClipMaskReveal.astro';

interface Props {
  eyebrow: string;
  headline: string;
  body: string;
  bgImageSrc: string;
  bgImageAlt: string;
}

const { eyebrow, headline, body, bgImageSrc, bgImageAlt } = Astro.props;
---

<section class="trust" id="trust" aria-labelledby="trust-title">
  <div class="trust__bg" aria-hidden="true">
    <KenBurnsImage
      src={bgImageSrc}
      alt={bgImageAlt}
      direction="drift"
      duration={28}
      intensity={0.25}
      aspectRatio="auto"
    />
    <div class="trust__bg-overlay"></div>
  </div>

  <div class="container trust__inner">
    <p class="trust__eyebrow eyebrow">{eyebrow}</p>
    <h2 id="trust-title" class="trust__title h2" data-animate>{headline}</h2>
    <p class="trust__body body" data-animate>{body}</p>

    <ClipMaskReveal
      direction="left"
      duration={0.9}
      ease="power2.inOut"
      delay={0.2}
      start="top 80%"
      class="trust__badge-wrap"
    >
      <div class="trust__badge">
        <span class="trust__badge-eyebrow">CENTRO TECNICO TACHIGRAFI</span>
        <span class="trust__badge-codice codice-tecnico">I3 044 1168</span>
        <span class="trust__badge-meta">
          Camera di Commercio Brindisi · Unioncamere Metrologia Legale
        </span>
        <span class="trust__badge-meta trust__badge-meta--muted">
          DM 10 agosto 2007 — art. 2 lett. i)
        </span>
      </div>
    </ClipMaskReveal>
  </div>
</section>

<style>
  .trust {
    position: relative;
    padding-block: var(--space-section);
    background: var(--color-bg);
    overflow: hidden;
  }

  .trust__bg {
    position: absolute;
    inset: 0;
    z-index: var(--z-bg);
    pointer-events: none;
  }
  .trust__bg :global(.kenburns) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    aspect-ratio: auto;
  }
  .trust__bg :global(.kenburns__img) {
    filter: grayscale(0.85) brightness(0.4) contrast(1.1);
  }
  .trust__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(21, 23, 26, 0.95) 0%,
      rgba(21, 23, 26, 0.85) 50%,
      rgba(21, 23, 26, 0.6) 100%
    );
  }

  .trust__inner {
    position: relative;
    z-index: var(--z-content);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-md);
    max-width: 1100px;
  }

  .trust__eyebrow {
    color: var(--color-accent);
  }

  .trust__title {
    color: var(--color-fg);
    max-width: 22ch;
    margin-bottom: var(--space-sm);
  }

  .trust__body {
    color: var(--color-fg-muted);
    max-width: 62ch;
    margin-bottom: var(--space-lg);
  }

  .trust__badge-wrap {
    margin-top: var(--space-md);
    align-self: start;
  }

  .trust__badge {
    display: inline-grid;
    grid-template-columns: minmax(0, auto);
    gap: 0.45rem;
    padding: 1.5rem 1.75rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-accent);
    border-left-width: 4px;
  }

  .trust__badge-eyebrow {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-fg-faint);
  }

  .trust__badge-codice {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: 0.02em;
  }

  .trust__badge-meta {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: 1.35;
  }
  .trust__badge-meta--muted {
    color: var(--color-fg-faint);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
  }
</style>
