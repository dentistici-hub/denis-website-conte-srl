---
/**
 * Conte srl — Signature HorizontalScrollTrack
 * Five chapter cards 01–05, scroll-pinned. The signature move owns 100% of
 * the page's Tier-1 scroll-choreography budget per concept §4.
 *
 * Chapter 04 ("Codice I3 044 1168") gets the load-bearing flag — larger
 * numeral, saffron border, the codice rendered as set type at largest weight.
 *
 * Mobile: HorizontalScrollTrack natively falls back to a horizontally-
 * scrollable native scroller via prefers-reduced-motion / @media. We add
 * a touch-device override to make it horizontally-scrollable for fingers.
 */
import HorizontalScrollTrack from '../motion/HorizontalScrollTrack.astro';
import ChapterCard from '../signature/ChapterCard.astro';
import type { ChapterCard as ChapterShape } from '../../data/placeholder';

interface Props {
  eyebrow: string;
  headline: string;
  chapters: ChapterShape[];
}

const { eyebrow, headline, chapters } = Astro.props;
---

<section class="signature" aria-labelledby="signature-title">
  <header class="container signature__header">
    <p class="signature__eyebrow eyebrow">{eyebrow}</p>
    <h2 id="signature-title" class="signature__title h2" data-animate>{headline}</h2>
    <p class="signature__hint" data-animate aria-hidden="true">
      <span>Scorrete in basso —</span>
      <span class="signature__hint-arrow" aria-hidden="true">↓</span>
      <span>cinque capitoli operativi.</span>
    </p>
  </header>

  <HorizontalScrollTrack
    gap="clamp(2rem, 4vw, 4rem)"
    padding="clamp(1.5rem, 5vw, 6rem)"
    speed={1.0}
    class="signature__track"
  >
    {chapters.map((c) => (
      <ChapterCard
        number={c.number}
        eyebrow={c.eyebrow}
        headline={c.headline}
        body={c.body}
        imageSrc={c.imageSrc}
        imageAlt={c.imageAlt}
        inlineValue={c.inlineValue}
        inlineValueLabel={c.inlineValueLabel}
        cta={c.cta}
        anchorId={c.anchorId}
        loadBearing={c.number === '04'}
      />
    ))}
  </HorizontalScrollTrack>
</section>

<style>
  .signature {
    background: var(--color-bg-dark);
    border-top: 1px solid var(--color-border-strong);
    border-bottom: 1px solid var(--color-border-strong);
    padding-top: var(--space-2xl);
  }

  .signature__header {
    max-width: 880px;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .signature__eyebrow {
    color: var(--color-accent);
  }

  .signature__title {
    color: var(--color-fg);
    max-width: 24ch;
  }

  .signature__hint {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-fg-faint);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .signature__hint-arrow {
    display: inline-block;
    color: var(--color-accent);
    transform: rotate(-90deg);
    font-size: 1.05rem;
  }

  /* Touch-device fallback — even without reduced-motion, the pinned scroll
   * pattern is awkward on mobile (the user wants to keep scrolling vertically
   * to reach contact). We trade scroll-jacking for native horizontal swipe. */
  @media (hover: none) and (pointer: coarse), (max-width: 700px) {
    .signature :global(.hscroll__viewport) {
      height: auto;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
    }
    .signature :global(.hscroll__track) {
      transform: none !important;
    }
    .signature :global(.chapter-card) {
      scroll-snap-align: start;
    }
  }
</style>
