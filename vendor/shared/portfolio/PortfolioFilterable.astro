---
import type { CaseStudy } from '../../types/content';

interface Props {
  cases: CaseStudy[];
  sectionTitle?: string;
  eyebrow?: string;
  /** Label + internal token for the "show everything" filter. Change to "Tutti" for Italian sites. */
  allLabel?: string;
}

const {
  cases,
  sectionTitle = 'Selected Projects',
  eyebrow = 'Our Work',
  allLabel = 'All',
} = Astro.props;

// Use a stable token that never ships to the UI; render allLabel for humans.
const ALL_TOKEN = '__all__';
const categories = [ALL_TOKEN, ...new Set(cases.map((c) => c.tags[0]))];

// Prefix asset paths with Astro's base URL so images resolve under GH Pages sub-path deploys.
const withBase = (p: string | undefined): string | undefined => {
  if (!p) return p;
  if (/^(https?:\/\/|data:)/.test(p)) return p;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return p.startsWith('/') ? `${base}${p}` : `${base}/${p}`;
};
---

<section class="portfolio section" id="projects" aria-labelledby="portfolio-title">
  <div class="container">
    <div class="portfolio__header" data-animate>
      <div class="portfolio__header-eyebrow">
        <span class="portfolio__eyebrow-line"></span>
        <span class="portfolio__eyebrow-text">{eyebrow}</span>
      </div>
      <h2 class="portfolio__title display" id="portfolio-title">{sectionTitle}</h2>
    </div>

    <!-- Filter buttons -->
    <div class="portfolio__filters" data-animate role="group" aria-label="Filter projects by category">
      {categories.map((cat) => (
        <button
          class={`portfolio__filter-btn${cat === ALL_TOKEN ? ' is-active' : ''}`}
          data-filter={cat}
          aria-pressed={cat === ALL_TOKEN ? 'true' : 'false'}
        >
          {cat === ALL_TOKEN ? allLabel : cat}
        </button>
      ))}
    </div>

    <!-- Projects grid -->
    <div class="portfolio__grid" id="portfolio-grid">
      {cases.map((project, i) => (
        <article
          class="portfolio__card"
          data-animate
          data-category={project.tags[0]}
          style={`--index: ${i}`}
        >
          {/* Image card — uses project.image when present, falls back to structural gradient */}
          <div class="portfolio__card-image">
            {project.image ? (
              <img
                class="portfolio__card-img"
                src={withBase(project.image)}
                alt={project.title}
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="portfolio__card-bg" aria-hidden="true"></div>
            )}
            <div class="portfolio__card-overlay">
              <span class="portfolio__card-client display">{project.client}</span>
            </div>
          </div>

          <div class="portfolio__card-body">
            <h3 class="portfolio__card-title display">{project.title}</h3>
            <p class="portfolio__card-desc">{project.description}</p>
            <div class="portfolio__card-tags">
              {project.tags.map((tag) => (
                <span class="portfolio__card-tag">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio__header {
    margin-bottom: var(--space-lg);
  }

  .portfolio__header-eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .portfolio__eyebrow-line {
    display: block;
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .portfolio__eyebrow-text {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .portfolio__title {
    font-size: var(--text-3xl);
  }

  .portfolio__filters {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .portfolio__filter-btn {
    padding: 8px 20px;
    border: 2px solid var(--color-border);
    background: transparent;
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-fg-muted);
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-body);
  }

  .portfolio__filter-btn:hover,
  .portfolio__filter-btn.is-active {
    background: var(--color-fg);
    border-color: var(--color-fg);
    color: var(--color-bg);
  }

  .portfolio__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .portfolio__card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
  }

  .portfolio__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1);
  }

  .portfolio__card.is-hidden {
    display: none;
  }

  .portfolio__card-image {
    position: relative;
    height: 220px;
    overflow: hidden;
  }

  .portfolio__card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .portfolio__card:hover .portfolio__card-img {
    transform: scale(1.05);
  }

  .portfolio__card-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-bg-dark) 0%, #2a3a4a 100%);
    /* Structural texture */
    background-image:
      linear-gradient(135deg, #1a2a3a 0%, #2a3a4a 100%),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 10px,
        rgba(8, 145, 178, 0.04) 10px,
        rgba(8, 145, 178, 0.04) 11px
      );
    background-blend-mode: normal;
  }

  .portfolio__card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: var(--space-md);
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 60%);
  }

  .portfolio__card-client {
    font-size: var(--text-sm);
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }

  .portfolio__card-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .portfolio__card-title {
    font-size: var(--text-xl);
    color: var(--color-fg);
  }

  .portfolio__card-desc {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
  }

  .portfolio__card-tags {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
    margin-top: var(--space-xs);
  }

  .portfolio__card-tag {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    background: var(--color-bg-card);
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .portfolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.portfolio__filter-btn');
  const cards = document.querySelectorAll('.portfolio__card') as NodeListOf<HTMLElement>;

  const ALL_TOKEN = '__all__';

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter || ALL_TOKEN;

      // Update active state
      filterBtns.forEach((b) => {
        b.classList.remove('is-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-pressed', 'true');

      // Filter cards
      cards.forEach((card) => {
        const category = card.dataset.category || '';
        if (filter === ALL_TOKEN || category === filter) {
          card.classList.remove('is-hidden');
        } else {
          card.classList.add('is-hidden');
        }
      });
    });
  });
</script>
