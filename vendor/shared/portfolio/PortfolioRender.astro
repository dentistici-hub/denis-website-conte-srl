---
/**
 * PortfolioRender — architectural/context renders with a "lens" inset showing
 * the detail or product shot. On hover/focus the lens expands.
 *
 * `renderImage` (large context shot) falls back to `image`. `detailImage` falls
 * back to `image` too, so sites with only one photo per case still render
 * coherently (lens shows the same image, zoomed).
 *
 * Reference inspiration: Jonite product-in-context grids — large render
 * dominates the card, a small framed inset shows the detail shot.
 */
import type { CaseStudy } from '../../types/content';

// Extend CaseStudy inline so we don't mutate the shared types file.
type RenderCase = CaseStudy & {
  renderImage?: string;
  detailImage?: string;
};

interface Props {
  cases: RenderCase[];
  sectionTitle?: string;
  eyebrow?: string;
  /** Aria label for the lens inset, e.g. "Product detail". */
  detailLabel?: string;
}

const {
  cases,
  sectionTitle = 'Projects in Context',
  eyebrow = 'Portfolio',
  detailLabel = 'Detail view',
} = Astro.props;
---

<section class="prender section" aria-labelledby="prender-title">
  <div class="container">
    <header class="prender__header" data-animate>
      {eyebrow && (
        <div class="prender__eyebrow">
          <span class="prender__eyebrow-line" aria-hidden="true"></span>
          <span class="prender__eyebrow-text">{eyebrow}</span>
        </div>
      )}
      <h2 class="prender__title display" id="prender-title">{sectionTitle}</h2>
    </header>

    <div class="prender__grid">
      {cases.map((study, i) => {
        const render = study.renderImage ?? study.image;
        const detail = study.detailImage ?? study.image;
        return (
          <article class="prender__card" data-animate data-delay={String(i * 0.08)} data-prender-card>
            <div class="prender__render-wrap">
              {render ? (
                <img
                  class="prender__render"
                  src={render}
                  alt={`${study.title} in context`}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="prender__render prender__placeholder" aria-hidden="true">
                  <span>{study.client}</span>
                </div>
              )}

              <button
                type="button"
                class="prender__lens"
                data-prender-lens
                aria-label={`${detailLabel}: ${study.title}`}
                aria-expanded="false"
              >
                {detail && (
                  <img
                    class="prender__lens-img"
                    src={detail}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                )}
                <span class="prender__lens-frame" aria-hidden="true"></span>
              </button>
            </div>

            <div class="prender__meta">
              <span class="prender__client">{study.client}</span>
              <h3 class="prender__card-title display">{study.title}</h3>
              <p class="prender__desc">{study.description}</p>
              <div class="prender__tags">
                {study.tags.map((t) => <span class="prender__tag">{t}</span>)}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<script type="module">
  document.querySelectorAll('[data-prender-card]').forEach((card) => {
    const lens = card.querySelector<HTMLButtonElement>('[data-prender-lens]');
    if (!lens) return;

    const toggle = (on: boolean) => {
      card.classList.toggle('is-lens-open', on);
      lens.setAttribute('aria-expanded', String(on));
    };

    lens.addEventListener('click', () => toggle(!card.classList.contains('is-lens-open')));
    lens.addEventListener('mouseenter', () => toggle(true));
    lens.addEventListener('mouseleave', () => toggle(false));
    lens.addEventListener('focus', () => toggle(true));
    lens.addEventListener('blur', () => toggle(false));
  });
</script>

<style>
  .prender {
    background: var(--color-bg);
    padding-block: var(--space-xl);
  }

  .prender__header { margin-bottom: var(--space-lg); }

  .prender__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .prender__eyebrow-line { width: 32px; height: 2px; background: var(--color-accent); }

  .prender__eyebrow-text {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .prender__title {
    font-size: var(--text-3xl);
    color: var(--color-fg);
  }

  .prender__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .prender__card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .prender__render-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .prender__render {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1000ms var(--ease-out, ease);
  }

  .prender__card:hover .prender__render {
    transform: scale(1.04);
  }

  .prender__placeholder {
    background: var(--color-bg-card);
    display: flex;
    align-items: flex-end;
    padding: var(--space-md);
    color: var(--color-fg-faint);
    font-family: var(--font-display);
  }

  /* Lens inset — small by default, expands on hover/focus/click. */
  .prender__lens {
    position: absolute;
    right: var(--space-md);
    bottom: var(--space-md);
    width: clamp(120px, 22%, 200px);
    aspect-ratio: 1 / 1;
    padding: 0;
    border: 2px solid var(--color-accent);
    background: var(--color-bg-elevated);
    overflow: hidden;
    cursor: zoom-in;
    transition:
      width 380ms var(--ease-expo, cubic-bezier(0.2, 1, 0.3, 1)),
      aspect-ratio 380ms var(--ease-expo, cubic-bezier(0.2, 1, 0.3, 1)),
      box-shadow var(--duration-fast, 180ms) var(--ease-out, ease);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }

  .prender__card.is-lens-open .prender__lens,
  .prender__lens:focus-visible {
    width: min(70%, 420px);
    aspect-ratio: 4 / 3;
    cursor: zoom-out;
    outline: none;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
  }

  .prender__lens-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .prender__lens-frame {
    position: absolute;
    inset: 4px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    pointer-events: none;
  }

  .prender__meta {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .prender__client {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .prender__card-title {
    font-size: var(--text-xl);
    color: var(--color-fg);
  }

  .prender__desc {
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
    font-size: var(--text-sm);
  }

  .prender__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-xs);
  }

  .prender__tag {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    background: var(--color-bg-card);
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
  }

  @media (min-width: 900px) {
    .prender__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .prender__render,
    .prender__lens {
      transition: none !important;
    }
    .prender__card:hover .prender__render { transform: none; }
  }
</style>
