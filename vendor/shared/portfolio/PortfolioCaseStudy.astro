---
import type { CaseStudy } from '../../types/content';
interface Props { cases: CaseStudy[]; sectionTitle?: string; }
const { cases, sectionTitle = 'Selected Work' } = Astro.props;

const withBase = (p: string | undefined): string | undefined => {
  if (!p) return p;
  if (/^(https?:\/\/|data:)/.test(p)) return p;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return p.startsWith('/') ? `${base}${p}` : `${base}/${p}`;
};
---
<section class="portfolio section" id="work" aria-labelledby="portfolio-title">
  <div class="container">
    <h2 class="portfolio__title display" id="portfolio-title" data-animate>{sectionTitle}</h2>
  </div>
  <div class="portfolio__track">
    {cases.map((study) => (
      <article class="portfolio__card" data-animate>
        <div class="portfolio__image">
          {study.image ? (
            <img
              class="portfolio__image-img"
              src={withBase(study.image)}
              alt={study.title}
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="portfolio__image-placeholder">
              <span class="portfolio__image-label">{study.client}</span>
            </div>
          )}
        </div>
        <div class="portfolio__info">
          <div class="portfolio__tags">
            {study.tags.map((tag) => <span class="portfolio__tag">{tag}</span>)}
          </div>
          <h3 class="portfolio__card-title">{study.title}</h3>
          <p class="portfolio__card-desc">{study.description}</p>
        </div>
      </article>
    ))}
  </div>
</section>
<style>
  .portfolio__title { font-size: var(--text-3xl); margin-bottom: var(--space-xl); }
  .portfolio__track { display: flex; gap: var(--space-lg); padding-inline: var(--gutter); overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; }
  .portfolio__track::-webkit-scrollbar { display: none; }
  .portfolio__card { flex: 0 0 min(80vw, 600px); scroll-snap-align: start; }
  .portfolio__image { border-radius: 12px; overflow: hidden; margin-bottom: var(--space-md); aspect-ratio: 4 / 3; position: relative; }
  .portfolio__image-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.6s var(--ease-out, ease-out); }
  .portfolio__card:hover .portfolio__image-img { transform: scale(1.04); }
  .portfolio__image-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--color-bg-card); font-size: var(--text-2xl); font-family: var(--font-display); font-weight: 700; color: var(--color-fg-faint); }
  .portfolio__tags { display: flex; gap: var(--space-xs); margin-bottom: var(--space-sm); flex-wrap: wrap; }
  .portfolio__tag { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); padding: 2px 8px; border: 1px solid var(--color-accent); border-radius: 100px; }
  .portfolio__card-title { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; margin-bottom: var(--space-xs); }
  .portfolio__card-desc { color: var(--color-fg-muted); line-height: var(--leading-normal); }
</style>
