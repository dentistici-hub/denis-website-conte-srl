---
/**
 * PortfolioCarousel — horizontal slider with large portrait cards, peek layout,
 * arrow controls, keyboard nav, and touch/swipe.
 *
 * The track uses scroll-snap (native momentum and snap) + a pair of prev/next
 * buttons that scroll by one card. On the right edge, the next card peeks by
 * ~15% of the card width, signalling "there's more".
 *
 * Reference inspiration: GKC Architecture's projects carousel (large portraits,
 * generous whitespace, single-card focus with peek).
 */
import type { CaseStudy } from '../../types/content';

interface Props {
  cases: CaseStudy[];
  sectionTitle?: string;
  eyebrow?: string;
  prevLabel?: string;
  nextLabel?: string;
}

const {
  cases,
  sectionTitle = 'Featured Projects',
  eyebrow = 'Portfolio',
  prevLabel = 'Previous',
  nextLabel = 'Next',
} = Astro.props;
---

<section class="pcar section" aria-labelledby="pcar-title">
  <div class="container pcar__container">
    <header class="pcar__header" data-animate>
      {eyebrow && (
        <div class="pcar__eyebrow">
          <span class="pcar__eyebrow-line" aria-hidden="true"></span>
          <span class="pcar__eyebrow-text">{eyebrow}</span>
        </div>
      )}
      <div class="pcar__header-row">
        <h2 class="pcar__title display" id="pcar-title">{sectionTitle}</h2>
        <div class="pcar__controls" role="group" aria-label={`${sectionTitle} navigation`}>
          <button type="button" class="pcar__btn" data-pcar-prev aria-label={prevLabel}>
            <svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
              <path d="M15 5l-7 7 7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <button type="button" class="pcar__btn" data-pcar-next aria-label={nextLabel}>
            <svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
              <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </div>
    </header>
  </div>

  <div
    class="pcar__track"
    data-pcar-track
    tabindex="0"
    role="region"
    aria-roledescription="carousel"
    aria-label={sectionTitle}
  >
    {cases.map((study, i) => (
      <article class="pcar__card" data-pcar-slide aria-roledescription="slide" aria-label={`${i + 1} of ${cases.length}`}>
        <div class="pcar__img-wrap">
          {study.image ? (
            <img
              class="pcar__img"
              src={study.image}
              alt={study.title}
              loading={i < 2 ? 'eager' : 'lazy'}
              decoding="async"
            />
          ) : (
            <div class="pcar__placeholder" aria-hidden="true">
              <span>{study.client}</span>
            </div>
          )}
        </div>
        <div class="pcar__meta">
          <span class="pcar__client">{study.client}</span>
          <h3 class="pcar__card-title display">{study.title}</h3>
          <p class="pcar__desc">{study.description}</p>
          <div class="pcar__tags">
            {study.tags.map((t) => <span class="pcar__tag">{t}</span>)}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<script type="module">
  document.querySelectorAll('.pcar').forEach((root) => {
    const section = root as HTMLElement;
    const track = section.querySelector<HTMLElement>('[data-pcar-track]');
    const prev = section.querySelector<HTMLButtonElement>('[data-pcar-prev]');
    const next = section.querySelector<HTMLButtonElement>('[data-pcar-next]');
    const slides = Array.from(section.querySelectorAll<HTMLElement>('[data-pcar-slide]'));
    if (!track || !slides.length) return;

    const step = () => {
      const first = slides[0];
      const second = slides[1];
      if (second) return second.offsetLeft - first.offsetLeft;
      return first.getBoundingClientRect().width;
    };

    const scrollBy = (dir: 1 | -1) => {
      track.scrollBy({ left: dir * step(), behavior: 'smooth' });
    };

    prev?.addEventListener('click', () => scrollBy(-1));
    next?.addEventListener('click', () => scrollBy(1));

    track.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); scrollBy(1); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); scrollBy(-1); }
      else if (e.key === 'Home') { e.preventDefault(); track.scrollTo({ left: 0, behavior: 'smooth' }); }
      else if (e.key === 'End') { e.preventDefault(); track.scrollTo({ left: track.scrollWidth, behavior: 'smooth' }); }
    });

    // Disable buttons at edges.
    const update = () => {
      const max = track.scrollWidth - track.clientWidth;
      if (prev) prev.disabled = track.scrollLeft <= 2;
      if (next) next.disabled = track.scrollLeft >= max - 2;
    };
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  });
</script>

<style>
  .pcar {
    background: var(--color-bg);
    padding-block: var(--space-xl);
  }

  .pcar__container { margin-bottom: var(--space-lg); }

  .pcar__header-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .pcar__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .pcar__eyebrow-line { width: 32px; height: 2px; background: var(--color-accent); }

  .pcar__eyebrow-text {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .pcar__title {
    font-size: var(--text-3xl);
    color: var(--color-fg);
  }

  .pcar__controls {
    display: flex;
    gap: var(--space-xs);
  }

  .pcar__btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    color: var(--color-fg);
    display: grid;
    place-items: center;
    cursor: pointer;
    transition:
      background var(--duration-fast, 180ms) var(--ease-out, ease),
      color var(--duration-fast, 180ms) var(--ease-out, ease);
  }

  .pcar__btn:hover:not(:disabled),
  .pcar__btn:focus-visible {
    background: var(--color-accent);
    color: var(--color-bg);
    outline: none;
  }

  .pcar__btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .pcar__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: min(85vw, 440px);
    gap: var(--space-md);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-inline: var(--gutter, var(--space-md));
    padding-block: var(--space-sm);
    scrollbar-width: none;
    scroll-behavior: smooth;
  }

  .pcar__track::-webkit-scrollbar { display: none; }

  .pcar__track:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .pcar__card {
    scroll-snap-align: start;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .pcar__img-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .pcar__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 800ms var(--ease-out, ease);
  }

  .pcar__card:hover .pcar__img { transform: scale(1.03); }

  .pcar__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-card);
    display: flex;
    align-items: flex-end;
    padding: var(--space-md);
    color: var(--color-fg-faint);
    font-family: var(--font-display);
  }

  .pcar__meta {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .pcar__client {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .pcar__card-title {
    font-size: var(--text-xl);
    color: var(--color-fg);
  }

  .pcar__desc {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
  }

  .pcar__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-xs);
  }

  .pcar__tag {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    background: var(--color-bg-card);
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
  }

  @media (max-width: 540px) {
    .pcar__track { grid-auto-columns: 88vw; }
    .pcar__btn { width: 40px; height: 40px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pcar__track { scroll-behavior: auto; }
    .pcar__img { transition: none; }
    .pcar__card:hover .pcar__img { transform: none; }
  }
</style>
