---
/**
 * PortfolioBeforeAfter — draggable before/after image comparison slider.
 *
 * Each pair has its own draggable divider. Pointer + touch drag, plus arrow-key
 * keyboard control when the divider handle is focused. Accessible semantics via
 * role="slider" + aria-valuenow (0-100, reveal percentage of "after").
 *
 * Reference inspiration: classic Juxtapose/Twenty20 before-after sliders
 * (widely used on renovation and construction portfolio sites).
 */

interface ImageSpec {
  src: string;
  alt: string;
}

interface Pair {
  title: string;
  description?: string;
  before: ImageSpec;
  after: ImageSpec;
  /** CSS aspect-ratio for this pair's stage. Defaults to "3 / 2". */
  aspect?: string;
}

interface Props {
  pairs: Pair[];
  sectionTitle?: string;
  eyebrow?: string;
  /** Initial reveal percentage of the "after" image (0-1). */
  initialRatio?: number;
  /** Label badges overlaid on each side of the stage. */
  beforeLabel?: string;
  afterLabel?: string;
  /** Accessible label for the draggable handle. */
  handleLabel?: string;
}

const {
  pairs,
  sectionTitle = 'Before / After',
  eyebrow = 'Transformations',
  initialRatio = 0.5,
  beforeLabel = 'Before',
  afterLabel = 'After',
  handleLabel = 'Drag to compare before and after',
} = Astro.props;

const pct = Math.round(Math.min(Math.max(initialRatio, 0), 1) * 100);
---

<section class="pba section" aria-labelledby="pba-title">
  <div class="container">
    <header class="pba__header" data-animate>
      {eyebrow && (
        <div class="pba__eyebrow">
          <span class="pba__eyebrow-line" aria-hidden="true"></span>
          <span class="pba__eyebrow-text">{eyebrow}</span>
        </div>
      )}
      <h2 class="pba__title display" id="pba-title">{sectionTitle}</h2>
    </header>

    <div class="pba__list">
      {pairs.map((pair, i) => (
        <article class="pba__item" data-animate data-delay={String(i * 0.1)}>
          <div
            class="pba__stage"
            data-pba
            style={`--ratio: ${pct}%; aspect-ratio: ${pair.aspect ?? '3 / 2'};`}
          >
            <img
              class="pba__img pba__img--before"
              src={pair.before.src}
              alt={pair.before.alt}
              loading="lazy"
              decoding="async"
              draggable="false"
            />
            <img
              class="pba__img pba__img--after"
              data-pba-after
              src={pair.after.src}
              alt={pair.after.alt}
              loading="lazy"
              decoding="async"
              draggable="false"
            />

            <span class="pba__badge pba__badge--left" aria-hidden="true">{beforeLabel}</span>
            <span class="pba__badge pba__badge--right" aria-hidden="true">{afterLabel}</span>

            <div class="pba__divider" data-pba-divider aria-hidden="true"></div>

            <button
              type="button"
              class="pba__handle"
              data-pba-handle
              role="slider"
              tabindex="0"
              aria-label={`${handleLabel}: ${pair.title}`}
              aria-valuemin="0"
              aria-valuemax="100"
              aria-valuenow={pct}
              aria-valuetext={`${pct}% ${afterLabel.toLowerCase()}`}
            >
              <span class="pba__handle-bar" aria-hidden="true"></span>
              <svg class="pba__handle-icon" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
                <path d="M9 6l-5 6 5 6M15 6l5 6-5 6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>

          <div class="pba__text">
            <h3 class="pba__item-title display">{pair.title}</h3>
            {pair.description && <p class="pba__desc">{pair.description}</p>}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script type="module">
  document.querySelectorAll('[data-pba]').forEach((stageEl) => {
    const stage = stageEl as HTMLElement;
    const handle = stage.querySelector<HTMLButtonElement>('[data-pba-handle]');
    const afterWrap = stage.querySelector<HTMLElement>('[data-pba-after]');
    if (!handle || !afterWrap) return;

    const clamp = (v: number) => Math.max(0, Math.min(100, v));
    const getRatio = () => parseFloat(stage.style.getPropertyValue('--ratio')) || 50;

    const setRatio = (pct: number) => {
      const v = clamp(pct);
      stage.style.setProperty('--ratio', `${v}%`);
      handle.setAttribute('aria-valuenow', String(Math.round(v)));
    };

    const moveTo = (clientX: number) => {
      const rect = stage.getBoundingClientRect();
      const pct = ((clientX - rect.left) / rect.width) * 100;
      setRatio(pct);
    };

    let dragging = false;
    const onDown = (e: PointerEvent) => {
      dragging = true;
      handle.setPointerCapture?.(e.pointerId);
      moveTo(e.clientX);
    };
    const onMove = (e: PointerEvent) => {
      if (!dragging) return;
      moveTo(e.clientX);
    };
    const onUp = (e: PointerEvent) => {
      dragging = false;
      handle.releasePointerCapture?.(e.pointerId);
    };

    handle.addEventListener('pointerdown', onDown);
    handle.addEventListener('pointermove', onMove);
    handle.addEventListener('pointerup', onUp);
    handle.addEventListener('pointercancel', onUp);

    // Also allow clicking anywhere on the stage to jump the divider.
    stage.addEventListener('pointerdown', (e) => {
      if (e.target === handle || handle.contains(e.target as Node)) return;
      moveTo((e as PointerEvent).clientX);
    });

    handle.addEventListener('keydown', (e) => {
      const step = e.shiftKey ? 10 : 2;
      if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') {
        e.preventDefault();
        setRatio(getRatio() - step);
      } else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') {
        e.preventDefault();
        setRatio(getRatio() + step);
      } else if (e.key === 'Home') {
        e.preventDefault();
        setRatio(0);
      } else if (e.key === 'End') {
        e.preventDefault();
        setRatio(100);
      }
    });
  });
</script>

<style>
  .pba {
    background: var(--color-bg);
    padding-block: var(--space-xl);
  }

  .pba__header { margin-bottom: var(--space-lg); }

  .pba__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .pba__eyebrow-line { width: 32px; height: 2px; background: var(--color-accent); }

  .pba__eyebrow-text {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .pba__title {
    font-size: var(--text-3xl);
    color: var(--color-fg);
  }

  .pba__list {
    display: grid;
    gap: var(--space-xl);
  }

  .pba__item {
    display: grid;
    gap: var(--space-md);
  }

  .pba__stage {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    user-select: none;
    touch-action: none;
  }

  .pba__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .pba__img--after {
    /* Reveal width = --ratio of the stage; clip the rest. */
    clip-path: inset(0 calc(100% - var(--ratio, 50%)) 0 0);
  }

  .pba__divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--ratio, 50%);
    width: 2px;
    background: var(--color-accent);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .pba__handle {
    position: absolute;
    top: 50%;
    left: var(--ratio, 50%);
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid var(--color-accent);
    background: var(--color-bg-elevated);
    color: var(--color-fg);
    display: grid;
    place-items: center;
    cursor: ew-resize;
    touch-action: none;
  }

  .pba__handle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .pba__handle-bar {
    display: none;
  }

  .pba__badge {
    position: absolute;
    top: var(--space-sm);
    padding: 4px 10px;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    pointer-events: none;
  }

  .pba__badge--left { left: var(--space-sm); }
  .pba__badge--right { right: var(--space-sm); }

  .pba__item-title {
    font-size: var(--text-xl);
    color: var(--color-fg);
    margin-bottom: var(--space-xs);
  }

  .pba__desc {
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
    max-width: 60ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .pba__handle { transition: none; }
  }
</style>
