---
// Full-bleed image with a heavy dark-to-transparent gradient fading from the bottom.
// Text lives inside the gradient zone — Adriaans-inspired editorial feel.
// The gradient is exposed as a CSS custom property so starters can tune it.
import type { SiteConfig } from '../../types/content';

interface Props {
  site: SiteConfig;
  /** Full-bleed background image src. Required. */
  backgroundImage: string;
  /** Optional responsive srcset. */
  backgroundSrcset?: string;
  /** Sizes attribute. Defaults to 100vw. */
  backgroundSizes?: string;
  /** Alt for the background image. Defaults to an empty string (decorative). */
  backgroundAlt?: string;
  /** Small uppercase eyebrow line. */
  eyebrow?: string;
  /** Override the h1. Defaults to site.tagline. */
  headline?: string;
  /** Optional pull-quote (italic, accent, short) shown below the headline. */
  pullQuote?: string;
  /** Attribution line under the pull-quote. */
  pullQuoteCite?: string;
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  /**
   * Override the gradient stops. Passed straight into the CSS linear-gradient.
   * Example: "to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.6) 40%, transparent 80%".
   */
  gradient?: string;
}

const {
  site,
  backgroundImage,
  backgroundSrcset,
  backgroundSizes = '100vw',
  backgroundAlt = '',
  eyebrow = site.contact.city ?? '',
  headline = site.tagline,
  pullQuote,
  pullQuoteCite,
  primaryCtaLabel = 'Get in Touch',
  primaryCtaHref = '#contact',
  gradient = 'to top, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.7) 35%, rgba(0, 0, 0, 0.25) 65%, transparent 90%',
} = Astro.props;
---

<section
  class="hero"
  aria-label="Introduction"
  style={`--hero-gradient: linear-gradient(${gradient});`}
>
  <img
    class="hero__bg"
    src={backgroundImage}
    srcset={backgroundSrcset}
    sizes={backgroundSizes}
    alt={backgroundAlt}
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <div class="hero__gradient" aria-hidden="true"></div>

  <div class="hero__content container">
    {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
    <h1 class="hero__headline display">{headline}</h1>

    {pullQuote && (
      <blockquote class="hero__quote">
        <span class="hero__quote-text" set:html={pullQuote.replace(/\n/g, '<br />')} />
        {pullQuoteCite && <cite class="hero__quote-cite">{pullQuoteCite}</cite>}
      </blockquote>
    )}

    <div class="hero__actions">
      <a href={primaryCtaHref} class="hero__cta-primary">{primaryCtaLabel}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--color-bg);
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: var(--z-bg);
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
    background: var(--hero-gradient);
    z-index: calc(var(--z-bg) + 1);
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: var(--z-content);
    width: 100%;
    padding-top: calc(var(--space-2xl) + 72px);
    padding-bottom: clamp(3rem, 8vh, 6rem);
    max-width: var(--max-width, 1400px);
  }

  .hero__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 var(--space-md);
  }

  .hero__headline {
    font-size: var(--text-display);
    color: #fff;
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-lg);
    max-width: 18ch;
    text-wrap: balance;
  }

  .hero__quote {
    margin: 0 0 var(--space-lg);
    padding: 0 0 0 var(--space-md);
    border-left: 2px solid var(--color-accent);
    max-width: 44ch;
  }

  .hero__quote-text {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-xl);
    color: rgba(255, 255, 255, 0.92);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-sm);
  }

  .hero__quote-cite {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    font-style: normal;
    letter-spacing: 0.04em;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero__cta-primary {
    display: inline-flex;
    padding: 0.875rem 2rem;
    background: var(--color-accent);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: 2px;
    transition: background var(--duration-fast);
  }

  .hero__cta-primary:hover {
    background: var(--color-accent-hover);
  }
</style>
