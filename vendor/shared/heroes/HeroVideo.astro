---
// Full-bleed background video with a custom thin timeline scrubber (click-to-seek).
// GKC-inspired. The scrubber is the signature — controls are hidden, progress is visible.
import type { SiteConfig } from '../../types/content';

interface VideoSource {
  src: string;
  type: string;
}

interface Props {
  site: SiteConfig;
  /** Primary video src. At least one of `src` or `sources` is required. */
  src?: string;
  /** Alternative sources (webm, mp4) — rendered as <source> tags. */
  sources?: VideoSource[];
  /** Poster frame shown while the video loads. */
  poster?: string;
  /** Small eyebrow line above the headline. */
  eyebrow?: string;
  /** Override the h1. Defaults to site.tagline. */
  headline?: string;
  /** Optional single-line tagline shown below the headline. */
  tagline?: string;
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  /** Accessible label for the scrubber progress bar. */
  scrubberLabel?: string;
}

const {
  site,
  src,
  sources,
  poster,
  eyebrow = site.contact.city ?? '',
  headline = site.tagline,
  tagline,
  primaryCtaLabel = 'Get in Touch',
  primaryCtaHref = '#contact',
  secondaryCtaLabel,
  secondaryCtaHref,
  scrubberLabel = 'Video progress',
} = Astro.props;

if (!src && (!sources || sources.length === 0)) {
  throw new Error('HeroVideo: provide either `src` or at least one entry in `sources`.');
}
---

<section class="hero" aria-label="Introduction" data-hero-video>
  <video
    class="hero__video"
    data-hero-video-el
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster={poster}
    aria-hidden="true"
  >
    {sources?.map((s) => <source src={s.src} type={s.type} />)}
    {src && <source src={src} />}
  </video>

  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__content container">
    {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
    <h1 class="hero__headline display">{headline}</h1>
    {tagline && <p class="hero__tagline">{tagline}</p>}
    <div class="hero__actions">
      <a href={primaryCtaHref} class="hero__cta-primary">{primaryCtaLabel}</a>
      {secondaryCtaLabel && secondaryCtaHref && (
        <a href={secondaryCtaHref} class="hero__cta-secondary">{secondaryCtaLabel}</a>
      )}
    </div>
  </div>

  <div
    class="hero__scrubber"
    data-hero-scrubber
    role="slider"
    tabindex="0"
    aria-label={scrubberLabel}
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="0"
  >
    <div class="hero__scrubber-track">
      <div class="hero__scrubber-fill" data-hero-fill></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    background: var(--color-bg);
    isolation: isolate;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: var(--z-bg);
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.4) 0%,
      rgba(0, 0, 0, 0.15) 45%,
      rgba(0, 0, 0, 0.65) 100%
    );
    z-index: calc(var(--z-bg) + 1);
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: var(--z-content);
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: calc(var(--space-2xl) + 72px);
    padding-bottom: clamp(4.5rem, 11vh, 7rem);
    max-width: var(--max-width, 1400px);
  }

  .hero__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 var(--space-md);
  }

  .hero__headline {
    font-size: var(--text-display);
    color: #fff;
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-md);
    max-width: 18ch;
    text-wrap: balance;
  }

  .hero__tagline {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.82);
    line-height: var(--leading-snug);
    max-width: 52ch;
    margin: 0 0 var(--space-lg);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    align-items: center;
  }

  .hero__cta-primary {
    display: inline-flex;
    padding: 0.875rem 2rem;
    background: var(--color-accent);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: 2px;
    transition: background var(--duration-fast);
  }

  .hero__cta-primary:hover { background: var(--color-accent-hover); }

  .hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 0;
    font-size: var(--text-sm);
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    transition: border-color var(--duration-fast), color var(--duration-fast);
  }

  .hero__cta-secondary:hover { border-color: #fff; }

  /* Signature: thin custom scrubber at the bottom edge */
  .hero__scrubber {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 28px;
    display: flex;
    align-items: flex-end;
    padding: 0 var(--gutter, 2rem) 16px;
    z-index: var(--z-content);
    cursor: pointer;
    user-select: none;
  }

  .hero__scrubber:focus-visible {
    outline: none;
  }

  .hero__scrubber:focus-visible .hero__scrubber-track {
    box-shadow: 0 0 0 2px var(--color-accent);
  }

  .hero__scrubber-track {
    position: relative;
    flex: 1;
    height: 2px;
    background: rgba(255, 255, 255, 0.22);
    transition: height var(--duration-fast) var(--ease-out, ease-out);
  }

  .hero__scrubber:hover .hero__scrubber-track {
    height: 4px;
  }

  .hero__scrubber-fill {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0%;
    background: #fff;
    transition: width 100ms linear;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scrubber-fill { transition: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-hero-video]').forEach((root) => {
    const video = root.querySelector<HTMLVideoElement>('[data-hero-video-el]');
    const scrubber = root.querySelector<HTMLElement>('[data-hero-scrubber]');
    const fill = root.querySelector<HTMLElement>('[data-hero-fill]');
    if (!video || !scrubber || !fill) return;

    function updateProgress() {
      if (!video.duration || !isFinite(video.duration)) return;
      const pct = (video.currentTime / video.duration) * 100;
      fill.style.width = `${pct}%`;
      scrubber.setAttribute('aria-valuenow', String(Math.round(pct)));
    }

    function seekFromEvent(clientX: number) {
      if (!video.duration || !isFinite(video.duration)) return;
      const track = scrubber.querySelector<HTMLElement>('.hero__scrubber-track');
      if (!track) return;
      const rect = track.getBoundingClientRect();
      const ratio = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
      video.currentTime = ratio * video.duration;
      updateProgress();
    }

    video.addEventListener('timeupdate', updateProgress);
    video.addEventListener('loadedmetadata', updateProgress);

    scrubber.addEventListener('click', (e) => seekFromEvent(e.clientX));

    // Drag-to-seek.
    let dragging = false;
    scrubber.addEventListener('pointerdown', (e) => {
      dragging = true;
      scrubber.setPointerCapture(e.pointerId);
      seekFromEvent(e.clientX);
    });
    scrubber.addEventListener('pointermove', (e) => {
      if (dragging) seekFromEvent(e.clientX);
    });
    scrubber.addEventListener('pointerup', (e) => {
      dragging = false;
      try { scrubber.releasePointerCapture(e.pointerId); } catch {}
    });

    // Keyboard seeking (arrow keys = 5s steps, home/end = start/end).
    scrubber.addEventListener('keydown', (e) => {
      if (!video.duration || !isFinite(video.duration)) return;
      const step = 5;
      switch (e.key) {
        case 'ArrowLeft':
        case 'ArrowDown':
          video.currentTime = Math.max(0, video.currentTime - step);
          e.preventDefault();
          break;
        case 'ArrowRight':
        case 'ArrowUp':
          video.currentTime = Math.min(video.duration, video.currentTime + step);
          e.preventDefault();
          break;
        case 'Home':
          video.currentTime = 0;
          e.preventDefault();
          break;
        case 'End':
          video.currentTime = video.duration;
          e.preventDefault();
          break;
      }
      updateProgress();
    });

    // Pause when the section is off-screen to save battery.
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) void video.play().catch(() => {});
          else video.pause();
        });
      }, { threshold: 0.1 });
      io.observe(root);
    }
  });
</script>
