---
import type { SiteConfig, Stat } from '../../types/content';

interface Props {
  site: SiteConfig;
  stats: Stat[];
  /** Text shown in the small eyebrow line. Defaults to "{city}". */
  eyebrow?: string;
  /** Primary CTA text + anchor. */
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  /** Secondary CTA text + anchor. */
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  /** Optional pull-quote shown in the aside (use \n for line breaks). */
  pullQuote?: string;
  /** Attribution line under the pull-quote (e.g. "Role, Person Name"). */
  pullQuoteCite?: string;
}

const {
  site,
  stats,
  eyebrow = site.contact.city ?? '',
  primaryCtaLabel = 'Get in Touch',
  primaryCtaHref = '#contact',
  secondaryCtaLabel = 'Learn More',
  secondaryCtaHref = '#services',
  pullQuote,
  pullQuoteCite,
} = Astro.props;
---

<section class="hero" aria-label="Introduction">
  <div class="hero__inner container">
    <div class="hero__content">
      <p class="hero__eyebrow">{eyebrow}</p>
      <h1 class="hero__headline display">
        {site.tagline}
      </h1>
      <p class="hero__desc">
        {site.description}
      </p>
      <div class="hero__actions">
        <a href={primaryCtaHref} class="hero__cta-primary">{primaryCtaLabel}</a>
        <a href={secondaryCtaHref} class="hero__cta-secondary">{secondaryCtaLabel}</a>
      </div>
    </div>

    {pullQuote && (
      <div class="hero__aside" aria-hidden="true">
        <div class="hero__accent-block">
          <div class="hero__accent-inner">
            <blockquote class="hero__pull-quote display" set:html={pullQuote.replace(/\n/g, '<br />')} />
            {pullQuoteCite && <cite class="hero__pull-cite">{pullQuoteCite}</cite>}
          </div>
        </div>
      </div>
    )}
  </div>

  <div class="hero__stats container">
    {stats.map((stat) => (
      <div class="hero__stat">
        <span class="hero__stat-value display">{stat.value}</span>
        <span class="hero__stat-label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--space-2xl) + 80px);
    padding-bottom: var(--space-xl);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  @media (min-width: 860px) {
    .hero__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .hero__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .hero__headline {
    font-size: var(--text-display);
    color: var(--color-fg);
    margin-bottom: var(--space-lg);
    max-width: 14ch;
  }

  .hero__desc {
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
    max-width: 52ch;
    margin-bottom: var(--space-lg);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
  }

  .hero__cta-primary {
    display: inline-flex;
    padding: 0.875rem 2rem;
    background: var(--color-accent);
    color: white;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: 2px;
    text-decoration: none;
    transition: background var(--duration-fast);
  }

  .hero__cta-primary:hover {
    background: var(--color-accent-hover);
  }

  .hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-fg-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-strong);
    padding-bottom: 2px;
    transition: color var(--duration-fast), border-color var(--duration-fast);
  }

  .hero__cta-secondary:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* Right aside — editorial accent block */
  .hero__aside {
    display: none;
  }

  @media (min-width: 860px) {
    .hero__aside { display: block; }
  }

  .hero__accent-block {
    background: var(--color-accent-light);
    border-left: 3px solid var(--color-accent);
    padding: var(--space-xl);
    position: relative;
  }

  .hero__pull-quote {
    font-size: var(--text-2xl);
    color: var(--color-accent);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-md);
    font-style: italic;
  }

  .hero__pull-cite {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    font-style: normal;
    display: block;
  }

  /* Stats strip */
  .hero__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .hero__stats { grid-template-columns: repeat(4, 1fr); }
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-lg) var(--space-md);
    background: var(--color-bg);
    text-align: center;
    gap: var(--space-xs);
  }

  .hero__stat-value {
    font-size: var(--text-3xl);
    color: var(--color-accent);
    line-height: 1;
  }

  .hero__stat-label {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }
</style>
