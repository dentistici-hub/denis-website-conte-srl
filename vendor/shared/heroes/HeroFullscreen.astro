---
// Full-viewport image/video hero with overlay text and parallax scroll-away.
// Content scrolls upward faster than the background media, creating depth.
// Accepts EITHER `image` (with optional srcset) OR `video` (with poster).
import type { SiteConfig } from '../../types/content';

interface HeroImage {
  src: string;
  /** Optional responsive srcset. */
  srcset?: string;
  /** Optional sizes attribute. Defaults to 100vw. */
  sizes?: string;
  /** Required descriptive alt text. */
  alt: string;
}

interface HeroVideo {
  src: string;
  /** Poster image shown while the video loads. Strongly recommended. */
  poster?: string;
  /** Optional list of alternative sources (webm, mp4) for <source> tags. */
  sources?: { src: string; type: string }[];
}

interface Props {
  site: SiteConfig;
  /** Small uppercase line above the headline. */
  eyebrow?: string;
  /** Override the h1. Defaults to site.tagline. */
  headline?: string;
  /** Optional single-line tagline shown below the headline. */
  tagline?: string;
  /** Primary CTA text + anchor. */
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  /** Secondary CTA text + anchor. */
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  /** Supply EITHER image OR video. If both are passed, video wins. */
  image?: HeroImage;
  video?: HeroVideo;
  /** Parallax strength for the content layer (0 disables). Default 0.25. */
  parallaxStrength?: number;
}

const {
  site,
  eyebrow = site.contact.city ?? '',
  headline = site.tagline,
  tagline,
  primaryCtaLabel = 'Get in Touch',
  primaryCtaHref = '#contact',
  secondaryCtaLabel,
  secondaryCtaHref,
  image,
  video,
  parallaxStrength = 0.25,
} = Astro.props;
---

<section class="hero" aria-label="Introduction" data-hero-fullscreen data-parallax={parallaxStrength}>
  <div class="hero__bg" data-hero-bg aria-hidden="true">
    {video ? (
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={video.poster}
      >
        {video.sources?.map((s) => <source src={s.src} type={s.type} />)}
        {!video.sources && <source src={video.src} />}
      </video>
    ) : image ? (
      <img
        class="hero__img"
        src={image.src}
        srcset={image.srcset}
        sizes={image.sizes ?? '100vw'}
        alt={image.alt}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    ) : (
      <div class="hero__placeholder" role="presentation"></div>
    )}
    <div class="hero__scrim"></div>
  </div>

  <div class="hero__content container" data-hero-content>
    {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
    <h1 class="hero__headline display">{headline}</h1>
    {tagline && <p class="hero__tagline">{tagline}</p>}
    <div class="hero__actions">
      <a href={primaryCtaHref} class="hero__cta-primary">{primaryCtaLabel}</a>
      {secondaryCtaLabel && secondaryCtaHref && (
        <a href={secondaryCtaHref} class="hero__cta-secondary">{secondaryCtaLabel}</a>
      )}
    </div>
  </div>

  <div class="hero__scroll-cue" aria-hidden="true">
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    background: var(--color-bg);
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: -5% 0;
    z-index: var(--z-bg);
    will-change: transform;
  }

  .hero__img,
  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-elevated);
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.45) 0%,
      rgba(0, 0, 0, 0.2) 40%,
      rgba(0, 0, 0, 0.55) 100%
    );
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: var(--z-content);
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: clamp(4rem, 10vh, 8rem);
    padding-top: calc(var(--space-2xl) + 72px);
    max-width: var(--max-width, 1400px);
    will-change: transform;
  }

  .hero__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-md);
  }

  .hero__headline {
    font-size: var(--text-display);
    color: #fff;
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-md);
    max-width: 18ch;
    text-wrap: balance;
  }

  .hero__tagline {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.82);
    line-height: var(--leading-snug);
    max-width: 52ch;
    margin: 0 0 var(--space-lg);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
  }

  .hero__cta-primary {
    display: inline-flex;
    padding: 0.875rem 2rem;
    background: var(--color-accent);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: 2px;
    transition: background var(--duration-fast);
  }

  .hero__cta-primary:hover {
    background: var(--color-accent-hover);
  }

  .hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 0;
    font-size: var(--text-sm);
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.55);
    transition: border-color var(--duration-fast), color var(--duration-fast);
  }

  .hero__cta-secondary:hover {
    border-color: #fff;
    color: var(--color-accent-hover, var(--color-accent));
  }

  .hero__scroll-cue {
    position: absolute;
    bottom: var(--space-lg);
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--z-content);
    pointer-events: none;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: rgba(255, 255, 255, 0.7);
    transform-origin: top center;
    animation: hero-scroll 2s var(--ease-in-out, ease-in-out) infinite;
  }

  @keyframes hero-scroll {
    0% { transform: scaleY(0); opacity: 0; }
    40% { transform: scaleY(1); opacity: 1; }
    80% { transform: scaleY(1); opacity: 0; }
    100% { transform: scaleY(0); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-line { animation: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-hero-fullscreen]').forEach((root) => {
    const bg = root.querySelector<HTMLElement>('[data-hero-bg]');
    const content = root.querySelector<HTMLElement>('[data-hero-content]');
    if (!bg || !content) return;

    const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) return;

    const strength = Number(root.dataset.parallax ?? 0.25);
    let raf = 0;
    let latestY = 0;

    function update() {
      raf = 0;
      const rect = root.getBoundingClientRect();
      if (rect.bottom < 0 || rect.top > window.innerHeight) return;
      // Background moves slower than scroll (classic parallax).
      bg.style.transform = `translate3d(0, ${latestY * strength}px, 0)`;
      // Content scrolls upward faster than the background (scroll-away).
      content.style.transform = `translate3d(0, ${-latestY * strength * 1.6}px, 0)`;
      content.style.opacity = String(Math.max(0, 1 - Math.abs(latestY) / (window.innerHeight * 0.9)));
    }

    function onScroll() {
      latestY = window.scrollY;
      if (!raf) raf = requestAnimationFrame(update);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    update();
  });
</script>
