---
// Text on one side, media on the other. Staggered entrance animations.
// Reverse prop flips the order (useful for visual rhythm on long pages).
import type { SiteConfig } from '../../types/content';

interface Media {
  type: 'image' | 'video';
  src: string;
  /** Required for images; optional for videos (used as caption fallback). */
  alt: string;
  /** Video only. Poster frame shown while loading. */
  poster?: string;
  /** Image only. Responsive srcset. */
  srcset?: string;
  /** Image only. Sizes attribute. */
  sizes?: string;
}

interface Props {
  site: SiteConfig;
  media: Media;
  /** If true, media is on the left and text on the right. */
  reverse?: boolean;
  eyebrow?: string;
  /** Override the h1. Defaults to site.tagline. */
  headline?: string;
  /** Override the description. Defaults to site.description. */
  description?: string;
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
}

const {
  site,
  media,
  reverse = false,
  eyebrow = site.contact.city ?? '',
  headline = site.tagline,
  description = site.description,
  primaryCtaLabel = 'Get in Touch',
  primaryCtaHref = '#contact',
  secondaryCtaLabel,
  secondaryCtaHref,
} = Astro.props;
---

<section class="hero" class:list={[{ 'hero--reverse': reverse }]} aria-label="Introduction">
  <div class="hero__inner container">
    <div class="hero__text">
      {eyebrow && <p class="hero__eyebrow" style="--hero-delay: 0ms">{eyebrow}</p>}
      <h1 class="hero__headline display" style="--hero-delay: 120ms">{headline}</h1>
      {description && <p class="hero__desc" style="--hero-delay: 240ms">{description}</p>}
      <div class="hero__actions" style="--hero-delay: 360ms">
        <a href={primaryCtaHref} class="hero__cta-primary">{primaryCtaLabel}</a>
        {secondaryCtaLabel && secondaryCtaHref && (
          <a href={secondaryCtaHref} class="hero__cta-secondary">{secondaryCtaLabel}</a>
        )}
      </div>
    </div>

    <div class="hero__media" style="--hero-delay: 180ms">
      {media.type === 'video' ? (
        <video
          class="hero__media-el"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster={media.poster}
          aria-label={media.alt}
        >
          <source src={media.src} />
        </video>
      ) : (
        <img
          class="hero__media-el"
          src={media.src}
          srcset={media.srcset}
          sizes={media.sizes ?? '(min-width: 960px) 50vw, 100vw'}
          alt={media.alt}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-bg);
    padding-top: calc(var(--space-2xl) + 72px);
    padding-bottom: var(--space-2xl);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero__inner {
      grid-template-columns: 1.05fr 1fr;
      gap: clamp(var(--space-lg), 4vw, var(--space-2xl));
    }
    .hero--reverse .hero__text { order: 2; }
    .hero--reverse .hero__media { order: 1; }
  }

  /* Staggered entrance */
  .hero__eyebrow,
  .hero__headline,
  .hero__desc,
  .hero__actions,
  .hero__media {
    opacity: 0;
    transform: translate3d(0, 24px, 0);
    animation: hero-rise 900ms var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)) forwards;
    animation-delay: var(--hero-delay, 0ms);
  }

  .hero__media {
    transform: translate3d(0, 40px, 0);
  }

  @keyframes hero-rise {
    to { opacity: 1; transform: translate3d(0, 0, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__eyebrow,
    .hero__headline,
    .hero__desc,
    .hero__actions,
    .hero__media {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  .hero__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 var(--space-md);
  }

  .hero__headline {
    font-size: var(--text-display);
    color: var(--color-fg);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-md);
    max-width: 14ch;
    text-wrap: balance;
  }

  .hero__desc {
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed, var(--leading-normal));
    max-width: 48ch;
    margin: 0 0 var(--space-lg);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
  }

  .hero__cta-primary {
    display: inline-flex;
    padding: 0.875rem 2rem;
    background: var(--color-accent);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: 2px;
    transition: background var(--duration-fast);
  }

  .hero__cta-primary:hover {
    background: var(--color-accent-hover);
  }

  .hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-fg-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2px;
    transition: color var(--duration-fast), border-color var(--duration-fast);
  }

  .hero__cta-secondary:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .hero__media {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--color-bg-elevated);
    overflow: hidden;
    border-radius: 4px;
  }

  @media (min-width: 960px) {
    .hero__media { aspect-ratio: 5 / 6; }
  }

  .hero__media-el {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
