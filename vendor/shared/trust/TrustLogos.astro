---
import type { LogoItem } from '../../types/content';
interface Props { logos: LogoItem[]; label?: string; }
const { logos, label = 'Trusted by' } = Astro.props;

const withBase = (p: string | undefined): string | undefined => {
  if (!p) return p;
  if (/^(https?:\/\/|data:)/.test(p)) return p;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return p.startsWith('/') ? `${base}${p}` : `${base}/${p}`;
};
---
<section class="trust section" aria-label={label}>
  <div class="container">
    <p class="trust__label" data-animate>{label}</p>
    <div class="trust__grid" data-animate>
      {logos.map((logo) => (
        <div class="trust__item" title={logo.name}>
          {logo.image ? (
            <img class="trust__logo" src={withBase(logo.image)} alt={logo.name} loading="lazy" decoding="async" />
          ) : (
            <span class="trust__name">{logo.name}</span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .trust { padding-block: var(--space-xl); }
  .trust__label { text-align: center; font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-fg-faint); margin-bottom: var(--space-lg); }
  .trust__grid { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: var(--space-xl); }
  .trust__item { opacity: 0.4; transition: opacity 0.3s; display: flex; align-items: center; justify-content: center; }
  .trust__item:hover { opacity: 1; }
  .trust__name { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; color: var(--color-fg-muted); }
  .trust__logo { height: 40px; width: auto; max-width: 180px; object-fit: contain; filter: grayscale(1); transition: filter 0.3s; }
  .trust__item:hover .trust__logo { filter: grayscale(0); }
</style>
