---
/**
 * BuilderBadge — sales-pitch banner that links to /dietro-le-quinte.
 *
 * Visible only when isDemo=true. Disappears the moment the site is
 * promoted to production (the disclosure page is for the buyer to read
 * during handoff, not for end users).
 *
 * Inject in homepage just above the footer. Discrete strip, monospace
 * type, neutral coloring — clearly Denis's voice (the builder), not the
 * client brand.
 */

interface Props {
  isDemo?: boolean;
  /** Override the link target. Default: /dietro-le-quinte */
  href?: string;
  /** Override the label. Default: "Come ho costruito il sito e perché" */
  label?: string;
}

const {
  isDemo = true,
  href = '/dietro-le-quinte',
  label = 'Come ho costruito il sito e perché',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolvedHref = href.startsWith('/') ? `${base}${href}` : href;
---

{isDemo && (
  <aside class="builder-badge" role="complementary" aria-label="Documentazione tecnica del builder">
    <a href={resolvedHref} class="builder-badge__link">
      <span class="builder-badge__eyebrow">Per chi ha commissionato il sito</span>
      <span class="builder-badge__label">{label}</span>
      <span class="builder-badge__arrow" aria-hidden="true">→</span>
    </a>
  </aside>
)}

<style>
  .builder-badge {
    background: color-mix(in srgb, var(--color-fg, #111) 92%, transparent);
    color: var(--color-bg, #fff);
    padding-block: clamp(1.25rem, 2.5vw, 2rem);
    padding-inline: var(--space-md, 1.5rem);
    border-top: 1px solid color-mix(in srgb, var(--color-fg, #111) 30%, transparent);
  }

  .builder-badge__link {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    max-width: 880px;
    margin: 0 auto;
    color: inherit;
    text-decoration: none;
    transition: opacity 200ms;
  }

  .builder-badge__link:hover {
    opacity: 0.85;
  }

  .builder-badge__eyebrow {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: color-mix(in srgb, currentColor 50%, transparent);
  }

  .builder-badge__label {
    font-size: clamp(1.05rem, 2vw, 1.4rem);
    line-height: 1.25;
    letter-spacing: -0.005em;
    font-weight: 500;
  }

  .builder-badge__arrow {
    align-self: flex-start;
    margin-top: 0.25rem;
    font-size: 1.25rem;
    color: color-mix(in srgb, currentColor 70%, transparent);
    transition: transform 200ms;
  }

  .builder-badge__link:hover .builder-badge__arrow {
    transform: translateX(4px);
    color: currentColor;
  }

  @media (min-width: 720px) {
    .builder-badge__link {
      flex-direction: row;
      align-items: center;
      gap: var(--space-md, 1.5rem);
    }
    .builder-badge__eyebrow {
      flex-shrink: 0;
      width: 200px;
    }
    .builder-badge__label {
      flex: 1;
    }
    .builder-badge__arrow {
      align-self: center;
      margin-top: 0;
    }
  }
</style>
