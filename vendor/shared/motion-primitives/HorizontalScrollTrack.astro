---
/**
 * HorizontalScrollTrack — converts vertical scroll into horizontal movement
 * of a wide content track. The section pins while the track translates left.
 *
 * This is the "pinned horizontal scroll" pattern used by portfolio carousels,
 * case-study rows, and process timelines on award sites. It signals "there is
 * more here, keep going" without adding a new page.
 *
 * How it works:
 *   - The outer section pins for N viewports of scroll distance.
 *   - The inner `.track` has `display: flex` and children arranged horizontally.
 *   - As scroll progresses from 0 to 1, translateX moves from 0 to
 *     -(trackWidth - viewportWidth), so the last child lands flush right.
 *
 * Props:
 *   - gap: string — CSS gap between items. Default `'clamp(1rem, 4vw, 4rem)'`.
 *   - padding: string — inline padding of the track. Default
 *       `'clamp(1rem, 5vw, 6rem)'` — controls where item 1 starts.
 *   - speed: number — scroll distance multiplier. 1 = track width minus
 *       viewport. 1.2 = 20% slower (gives buffer). Default 1.0.
 *   - start: string — ScrollTrigger start. Default `'top top'`.
 *   - id, class passthrough.
 *
 * Children are expected to be flex items (any shape). Give them a width so
 * the flex layout actually extends past the viewport.
 *
 * Usage:
 *   <HorizontalScrollTrack>
 *     <article class="track-card">Item 1</article>
 *     <article class="track-card">Item 2</article>
 *     ...
 *   </HorizontalScrollTrack>
 */
interface Props {
  gap?: string;
  padding?: string;
  speed?: number;
  start?: string;
  id?: string;
  class?: string;
}

const {
  gap = 'clamp(1rem, 4vw, 4rem)',
  padding = 'clamp(1rem, 5vw, 6rem)',
  speed = 1.0,
  start = 'top top',
  id,
  class: className = '',
} = Astro.props;
---

<section
  class:list={['hscroll', className]}
  data-hscroll-speed={String(speed)}
  data-hscroll-start={start}
  style={`--hscroll-gap: ${gap}; --hscroll-padding: ${padding};`}
  id={id}
>
  <div class="hscroll__viewport">
    <div class="hscroll__track">
      <slot />
    </div>
  </div>
</section>

<style>
  .hscroll {
    position: relative;
    width: 100%;
    overflow: clip;
  }
  .hscroll__viewport {
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .hscroll__track {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--hscroll-gap, 2rem);
    padding-inline: var(--hscroll-padding, 5vw);
    align-items: center;
    will-change: transform;
  }
  /* Reduced motion fallback — show natively scrollable track. */
  @media (prefers-reduced-motion: reduce) {
    .hscroll__viewport {
      height: auto;
      overflow-x: auto;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const w = window as unknown as { __mpGsap?: boolean };
  if (!w.__mpGsap) {
    gsap.registerPlugin(ScrollTrigger);
    w.__mpGsap = true;
  }

  const isReducedMotion = (): boolean =>
    typeof window !== 'undefined' && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function initHScroll(): void {
    const sections = document.querySelectorAll<HTMLElement>('.hscroll[data-hscroll-speed]');
    if (sections.length === 0) return;
    if (isReducedMotion()) return; // CSS handles the fallback.

    sections.forEach((section) => {
      if (section.dataset.hscrollInitialized === 'true') return;
      section.dataset.hscrollInitialized = 'true';

      const viewport = section.querySelector<HTMLElement>('.hscroll__viewport');
      const track = section.querySelector<HTMLElement>('.hscroll__track');
      if (!viewport || !track) return;

      const speed = parseFloat(section.dataset.hscrollSpeed || '1');
      const start = section.dataset.hscrollStart || 'top top';

      const computeDistance = (): number => {
        const trackWidth = track.scrollWidth;
        const viewportWidth = viewport.clientWidth;
        return Math.max(0, trackWidth - viewportWidth);
      };

      let distance = computeDistance();

      const trigger = ScrollTrigger.create({
        trigger: section,
        start,
        end: () => `+=${distance * speed}`,
        pin: viewport,
        pinSpacing: true,
        scrub: 0.8,
        anticipatePin: 1,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          gsap.set(track, { x: -distance * self.progress });
        },
      });

      // Recompute distance on resize — ScrollTrigger.refresh() will pick it up.
      const onResize = (): void => {
        distance = computeDistance();
        ScrollTrigger.refresh();
      };
      window.addEventListener('resize', onResize, { passive: true });
      // Store so we could tear down if we ever add dynamic cleanup.
      (trigger as unknown as { __onResize?: () => void }).__onResize = onResize;
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHScroll, { once: true });
  } else {
    initHScroll();
  }
</script>
