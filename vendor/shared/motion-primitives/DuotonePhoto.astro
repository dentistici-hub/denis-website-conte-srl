---
/**
 * DuotonePhoto — treats a photo with two brand colors using CSS blend-modes.
 * Greyscale base + color overlay in `multiply` mode, then a highlight tone
 * in `screen`. Zero JS.
 *
 * This converts any stock photo into brand-aligned art. Same photo, different
 * palette per client — avoids the "we used the same Unsplash image" look.
 *
 * Props:
 *   - src: string — required. Image path.
 *   - alt: string — required.
 *   - shadow: string — the "dark" color. Default `'#141414'`.
 *   - highlight: string — the "light" color. Default `'#ffffff'`.
 *   - intensity: 0..1 — how strong the duotone effect. 0 = original photo,
 *       1 = full duotone. Default 0.85.
 *   - aspectRatio: string — CSS aspect-ratio. Default none (natural).
 *   - class passthrough.
 *
 * Usage:
 *   <DuotonePhoto
 *     src="/images/team-portrait.jpg"
 *     alt="Our team in the studio"
 *     shadow="#0B1A2E"
 *     highlight="#F6F8FB"
 *     aspectRatio="4 / 5"
 *   />
 */
interface Props {
  src: string;
  alt: string;
  shadow?: string;
  highlight?: string;
  intensity?: number;
  aspectRatio?: string;
  class?: string;
}

const {
  src,
  alt,
  shadow = '#141414',
  highlight = '#ffffff',
  intensity = 0.85,
  aspectRatio,
  class: className = '',
} = Astro.props;

// Clamp intensity.
const i = Math.max(0, Math.min(1, intensity));
const ratioStyle = aspectRatio ? `aspect-ratio: ${aspectRatio};` : '';
---

<figure
  class:list={['duotone', className]}
  style={`--duo-shadow: ${shadow}; --duo-highlight: ${highlight}; --duo-intensity: ${i}; ${ratioStyle}`}
>
  <img class="duotone__img" src={src} alt={alt} loading="lazy" decoding="async" />
  <span class="duotone__shadow" aria-hidden="true"></span>
  <span class="duotone__highlight" aria-hidden="true"></span>
</figure>

<style>
  .duotone {
    position: relative;
    display: block;
    margin: 0;
    overflow: hidden;
    isolation: isolate;
    background: var(--duo-shadow, #141414);
  }
  .duotone__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05) brightness(1);
    opacity: calc(1 - var(--duo-intensity) * 0.3);
  }
  .duotone__shadow {
    position: absolute;
    inset: 0;
    background: var(--duo-shadow, #141414);
    mix-blend-mode: multiply;
    opacity: var(--duo-intensity, 0.85);
    pointer-events: none;
  }
  .duotone__highlight {
    position: absolute;
    inset: 0;
    background: var(--duo-highlight, #ffffff);
    mix-blend-mode: screen;
    opacity: calc(var(--duo-intensity, 0.85) * 0.6);
    pointer-events: none;
  }
</style>
