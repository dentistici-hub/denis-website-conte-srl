---
import type { SiteConfig } from '../../types/content';

interface HoursEntry {
  label: string;
  lines: string[];
  closed?: boolean;
}

interface Props {
  site: SiteConfig;
  /** Heading above the find-us column. */
  findUsHeading?: string;
  /** Heading above the hours column. */
  hoursHeading?: string;
  /** Hours rows. Each row has a label (dt) and one or more lines (dd). */
  hours?: HoursEntry[];
  /** Heading above the newsletter column. */
  newsletterHeading?: string;
  /** Short description under the newsletter heading. */
  newsletterDesc?: string;
}

const {
  site,
  findUsHeading = 'Find us',
  hoursHeading = 'Hours',
  hours = [],
  newsletterHeading = 'Stay in touch',
  newsletterDesc = 'Updates and occasional notes. Unsubscribe anytime.',
} = Astro.props;
const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner container">
    <div class="footer__col footer__col--brand">
      <p class="footer__brand display">{site.name}</p>
      <p class="footer__tagline">{site.tagline}</p>
    </div>

    <div class="footer__col footer__col--info">
      <h3 class="footer__col-heading">{findUsHeading}</h3>
      <address class="footer__address">
        {site.contact.address}<br />
        {site.contact.city}
      </address>
      {site.contact.phone && (
        <a href={`tel:${site.contact.phone}`} class="footer__contact-link">
          {site.contact.phone}
        </a>
      )}
      <a href={`mailto:${site.contact.email}`} class="footer__contact-link">
        {site.contact.email}
      </a>
    </div>

    {hours.length > 0 && (
      <div class="footer__col footer__col--hours">
        <h3 class="footer__col-heading">{hoursHeading}</h3>
        <dl class="footer__hours">
          {hours.map((entry) => (
            <>
              <dt class={entry.closed ? 'footer__hours-closed' : ''}>{entry.label}</dt>
              {entry.lines.map((line) => <dd>{line}</dd>)}
            </>
          ))}
        </dl>
      </div>
    )}

    <div class="footer__col footer__col--newsletter">
      <h3 class="footer__col-heading">{newsletterHeading}</h3>
      <p class="footer__newsletter-desc">{newsletterDesc}</p>
      <form class="footer__newsletter-form" novalidate>
        <label for="footer-email" class="sr-only">Email address</label>
        <input
          type="email"
          id="footer-email"
          name="email"
          placeholder="your@email.com"
          class="footer__newsletter-input"
          autocomplete="email"
        />
        <button type="submit" class="footer__newsletter-btn" aria-label="Subscribe">
          &rarr;
        </button>
      </form>

      {Object.entries(site.social).map(([name, url]) => (
        <a
          href={url}
          class="footer__social-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${site.name} on ${name}`}
        >
          {name.charAt(0).toUpperCase() + name.slice(1)}
        </a>
      ))}
    </div>
  </div>

  <div class="footer__bottom container">
    <p class="footer__copy">&copy; {year} {site.name}. All rights reserved.</p>
    <a href="/privacy" class="footer__legal">Privacy Policy</a>
    <a href="/dietro-le-quinte" class="footer__legal">Dietro le quinte</a>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-2xl);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .footer__brand {
    font-size: var(--text-xl);
    color: var(--color-fg);
    margin-bottom: var(--space-sm);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
    max-width: 200px;
  }

  .footer__col-heading {
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-fg-faint);
    margin-bottom: var(--space-md);
    font-weight: 400;
    font-family: var(--font-body);
  }

  .footer__address {
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-sm);
  }

  .footer__contact-link {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin-bottom: var(--space-xs);
    transition: color var(--duration-fast);
  }

  .footer__contact-link:hover {
    color: var(--color-fg);
  }

  .footer__hours {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
  }

  .footer__hours dt {
    color: var(--color-fg);
    margin-top: var(--space-sm);
  }

  .footer__hours dt:first-child {
    margin-top: 0;
  }

  .footer__hours dd {
    margin-left: 0;
  }

  .footer__hours-closed {
    color: var(--color-fg-faint) !important;
  }

  .footer__newsletter-desc {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin-bottom: var(--space-md);
    line-height: var(--leading-normal);
  }

  .footer__newsletter-form {
    display: flex;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: var(--space-md);
  }

  .footer__newsletter-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0.75em 1em;
    font-size: var(--text-sm);
    color: var(--color-fg);
    font-family: var(--font-body);
    outline: none;
  }

  .footer__newsletter-input::placeholder {
    color: var(--color-fg-faint);
  }

  .footer__newsletter-btn {
    background: transparent;
    border: none;
    border-left: 1px solid var(--color-border);
    padding: 0.75em 1em;
    color: var(--color-fg-muted);
    cursor: pointer;
    font-size: var(--text-base);
    transition: color var(--duration-fast), background var(--duration-fast);
  }

  .footer__newsletter-btn:hover {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .footer__social-link {
    display: inline-block;
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    transition: color var(--duration-fast);
  }

  .footer__social-link:hover {
    color: var(--color-fg);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-lg);
  }

  .footer__copy,
  .footer__legal {
    font-size: var(--text-xs);
    color: var(--color-fg-faint);
  }

  .footer__legal {
    transition: color var(--duration-fast);
  }

  .footer__legal:hover {
    color: var(--color-fg-muted);
  }

  @media (max-width: 1024px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
