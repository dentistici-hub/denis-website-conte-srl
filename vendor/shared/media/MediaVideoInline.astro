---
interface Props {
  src: string;
  poster?: string;
  captions?: string;
  label?: string;
  type?: string;
}

const { src, poster, captions, label, type = 'video/mp4' } = Astro.props;
const playerId = `video-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class="videoinline" aria-label={label ?? 'Video player'}>
  <div class="videoinline__frame">
    <video
      class="videoinline__media"
      id={playerId}
      data-video
      poster={poster}
      preload="metadata"
      playsinline
    >
      <source src={src} type={type} />
      {captions && (
        <track kind="captions" src={captions} srclang="en" label="Captions" default />
      )}
    </video>

    <div class="videoinline__controls" data-video-controls>
      <button
        type="button"
        class="videoinline__play"
        data-video-play
        aria-label="Play video"
        aria-pressed="false"
      >
        <svg class="videoinline__icon videoinline__icon--play" viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
          <path d="M7 4v16l13-8z" fill="currentColor" />
        </svg>
        <svg class="videoinline__icon videoinline__icon--pause" viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
          <path d="M6 4h4v16H6zM14 4h4v16h-4z" fill="currentColor" />
        </svg>
      </button>

      <div
        class="videoinline__progress"
        data-video-progress
        role="slider"
        tabindex="0"
        aria-label="Playback progress"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="0"
      >
        <div class="videoinline__progress-fill" data-video-fill></div>
        <div class="videoinline__progress-handle" data-video-handle></div>
      </div>

      <div class="videoinline__time" aria-hidden="true">
        <span data-video-current>0:00</span>
        <span class="videoinline__time-sep">/</span>
        <span data-video-duration>0:00</span>
      </div>
    </div>
  </div>

  {label && <figcaption class="videoinline__caption">{label}</figcaption>}
</figure>

<script>
  const formatTime = (seconds: number): string => {
    if (!isFinite(seconds) || seconds < 0) return '0:00';
    const m = Math.floor(seconds / 60);
    const s = Math.floor(seconds % 60);
    return `${m}:${s.toString().padStart(2, '0')}`;
  };

  const initVideo = (root: HTMLElement) => {
    const video = root.querySelector<HTMLVideoElement>('[data-video]');
    const playBtn = root.querySelector<HTMLButtonElement>('[data-video-play]');
    const progress = root.querySelector<HTMLElement>('[data-video-progress]');
    const fill = root.querySelector<HTMLElement>('[data-video-fill]');
    const handle = root.querySelector<HTMLElement>('[data-video-handle]');
    const currentEl = root.querySelector<HTMLElement>('[data-video-current]');
    const durationEl = root.querySelector<HTMLElement>('[data-video-duration]');

    if (!video || !playBtn || !progress || !fill) return;

    const setPlayState = (playing: boolean) => {
      root.classList.toggle('is-playing', playing);
      playBtn.setAttribute('aria-pressed', String(playing));
      playBtn.setAttribute('aria-label', playing ? 'Pause video' : 'Play video');
    };

    playBtn.addEventListener('click', () => {
      if (video.paused) video.play();
      else video.pause();
    });

    video.addEventListener('play', () => setPlayState(true));
    video.addEventListener('pause', () => setPlayState(false));
    video.addEventListener('ended', () => setPlayState(false));

    video.addEventListener('loadedmetadata', () => {
      if (durationEl) durationEl.textContent = formatTime(video.duration);
    });

    video.addEventListener('timeupdate', () => {
      const ratio = video.duration ? video.currentTime / video.duration : 0;
      const pct = ratio * 100;
      fill.style.width = `${pct}%`;
      if (handle) handle.style.left = `${pct}%`;
      if (currentEl) currentEl.textContent = formatTime(video.currentTime);
      progress.setAttribute('aria-valuenow', String(Math.round(pct)));
    });

    const seekFromEvent = (clientX: number) => {
      const rect = progress.getBoundingClientRect();
      const ratio = Math.min(1, Math.max(0, (clientX - rect.left) / rect.width));
      if (video.duration) video.currentTime = ratio * video.duration;
    };

    let dragging = false;

    progress.addEventListener('pointerdown', (e) => {
      dragging = true;
      progress.setPointerCapture(e.pointerId);
      seekFromEvent(e.clientX);
    });

    progress.addEventListener('pointermove', (e) => {
      if (dragging) seekFromEvent(e.clientX);
    });

    progress.addEventListener('pointerup', (e) => {
      dragging = false;
      try { progress.releasePointerCapture(e.pointerId); } catch {}
    });

    progress.addEventListener('keydown', (e) => {
      if (!video.duration) return;
      const step = video.duration * 0.05;
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        video.currentTime = Math.max(0, video.currentTime - step);
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        video.currentTime = Math.min(video.duration, video.currentTime + step);
      } else if (e.key === ' ' || e.key === 'Enter') {
        e.preventDefault();
        if (video.paused) video.play();
        else video.pause();
      }
    });
  };

  document.querySelectorAll<HTMLElement>('.videoinline').forEach(initVideo);
</script>

<style>
  .videoinline {
    margin: 0;
    padding: 0;
    color: var(--color-fg);
    font-family: var(--font-body);
  }

  .videoinline__frame {
    position: relative;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .videoinline__media {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    background: var(--color-bg);
  }

  .videoinline__controls {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: var(--space-sm) var(--space-md);
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: linear-gradient(
      to top,
      rgba(10, 10, 11, 0.85),
      rgba(10, 10, 11, 0)
    );
  }

  .videoinline__play {
    appearance: none;
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .videoinline__play:hover,
  .videoinline__play:focus-visible {
    background: var(--color-accent-hover);
    outline: none;
  }

  .videoinline__play:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .videoinline__icon--pause {
    display: none;
  }

  .videoinline.is-playing .videoinline__icon--play {
    display: none;
  }

  .videoinline.is-playing .videoinline__icon--pause {
    display: block;
  }

  .videoinline__progress {
    flex: 1;
    position: relative;
    height: 20px;
    display: flex;
    align-items: center;
    cursor: pointer;
    touch-action: none;
  }

  .videoinline__progress::before {
    content: '';
    position: absolute;
    inset: 50% 0 auto 0;
    height: 2px;
    transform: translateY(-50%);
    background: var(--color-border);
    border-radius: 1px;
  }

  .videoinline__progress-fill {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 2px;
    width: 0%;
    background: var(--color-accent);
    border-radius: 1px;
    pointer-events: none;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .videoinline__progress:hover .videoinline__progress-fill,
  .videoinline__progress:focus-visible .videoinline__progress-fill {
    background: var(--color-accent-hover);
  }

  .videoinline__progress-handle {
    position: absolute;
    top: 50%;
    left: 0%;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent);
    transform: translate(-50%, -50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .videoinline__progress:hover .videoinline__progress-handle,
  .videoinline__progress:focus-visible .videoinline__progress-handle {
    opacity: 1;
  }

  .videoinline__progress:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .videoinline__time {
    font-size: var(--text-xs);
    color: var(--color-fg);
    letter-spacing: 0.08em;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .videoinline__time-sep {
    color: var(--color-fg-muted);
    margin: 0 0.3em;
  }

  .videoinline__caption {
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
  }

  @media (prefers-reduced-motion: reduce) {
    .videoinline__play,
    .videoinline__progress-fill,
    .videoinline__progress-handle {
      transition: none;
    }
  }
</style>
