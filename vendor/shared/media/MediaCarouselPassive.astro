---
interface CarouselImage {
  src: string;
  alt: string;
  srcset?: string;
  sizes?: string;
}

interface Props {
  images: CarouselImage[];
  intervalMs?: number;
}

const { images, intervalMs = 5000 } = Astro.props;
---

<div
  class="carouselpassive"
  role="presentation"
  aria-hidden="true"
  data-carousel
  data-interval={intervalMs}
>
  {images.map((img, i) => (
    <picture class="carouselpassive__slide" data-slide data-active={i === 0 ? 'true' : undefined}>
      {img.srcset && <source srcset={img.srcset} sizes={img.sizes ?? '100vw'} />}
      <img
        class="carouselpassive__image"
        src={img.src}
        alt={img.alt}
        loading={i === 0 ? 'eager' : 'lazy'}
        decoding="async"
      />
    </picture>
  ))}
</div>

<script>
  const initCarousel = (root: HTMLElement) => {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
    if (slides.length <= 1) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (reduced.matches) return;

    const intervalMs = Math.max(1500, Number(root.dataset.interval ?? '5000'));
    let current = 0;
    let timer: number | null = null;

    const advance = () => {
      const next = (current + 1) % slides.length;
      slides[current].removeAttribute('data-active');
      slides[next].setAttribute('data-active', 'true');
      current = next;
    };

    const start = () => {
      if (timer !== null) return;
      timer = window.setInterval(advance, intervalMs);
    };

    const stop = () => {
      if (timer === null) return;
      window.clearInterval(timer);
      timer = null;
    };

    reduced.addEventListener('change', (e) => {
      if (e.matches) stop();
      else start();
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else start();
    });

    start();
  };

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel);
</script>

<style>
  .carouselpassive {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 240px;
    overflow: hidden;
    background: var(--color-bg-elevated);
  }

  .carouselpassive__slide {
    position: absolute;
    inset: 0;
    display: block;
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-out);
    will-change: opacity;
  }

  .carouselpassive__slide[data-active='true'] {
    opacity: 1;
  }

  .carouselpassive__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .carouselpassive__slide {
      transition: none;
    }
    /* The first slide remains visible; auto-advance is disabled in JS. */
  }
</style>
