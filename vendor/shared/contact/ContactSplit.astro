---
import type { SiteConfig } from '../../types/content';

interface Props {
  site: SiteConfig;
  /** Heading above the address. Defaults to "{city} Office" or "Contact". */
  officeTitle?: string;
  /** Short eyebrow text above the main title. */
  eyebrow?: string;
  /** Main title over the form. */
  title?: string;
  /** Intro paragraph under the title. */
  intro?: string;
  /** Optional confidentiality / privilege note shown under the address. */
  confidentialityNote?: string;
  /** Submit button label. */
  submitLabel?: string;
  /** Form action URL. If omitted, form has no action (no-op submit). */
  action?: string;
  /** Form method. Defaults to "POST". */
  method?: string;
  /** Required GDPR consent text (supports '{privacy}' placeholder for a linked privacy policy). If omitted, checkbox is hidden. */
  gdprConsentLabel?: string;
  privacyHref?: string;
}

const {
  site,
  officeTitle = site.contact.city ? `${site.contact.city} Office` : 'Contact',
  eyebrow = 'Get in Touch',
  title = 'Schedule a Consultation',
  intro = 'A member of our team will respond within one business day.',
  confidentialityNote,
  submitLabel = 'Send Message',
  action,
  method = 'POST',
  gdprConsentLabel,
  privacyHref,
} = Astro.props;
---

<section class="contact section" id="contact" aria-labelledby="contact-title">
  <div class="container">
    <div class="contact__grid">
      <div class="contact__form-col" data-animate>
        <p class="contact__eyebrow">{eyebrow}</p>
        <h2 class="contact__title display" id="contact-title">{title}</h2>
        <p class="contact__intro">{intro}</p>

        <form class="contact__form" name="contact" method={action ? method : undefined} action={action} novalidate>
          <div class="contact__row">
            <div class="contact__field">
              <label class="contact__label" for="cf-name">Full Name</label>
              <input class="contact__input" id="cf-name" name="name" type="text" required autocomplete="name" placeholder="Marco Rossi" />
            </div>
            <div class="contact__field">
              <label class="contact__label" for="cf-company">Company</label>
              <input class="contact__input" id="cf-company" name="company" type="text" autocomplete="organization" placeholder="Rossi S.p.A." />
            </div>
          </div>
          <div class="contact__row">
            <div class="contact__field">
              <label class="contact__label" for="cf-email">Email Address</label>
              <input class="contact__input" id="cf-email" name="email" type="email" required autocomplete="email" placeholder="m.rossi@example.com" />
            </div>
            <div class="contact__field">
              <label class="contact__label" for="cf-phone">Phone (optional)</label>
              <input class="contact__input" id="cf-phone" name="phone" type="tel" autocomplete="tel" placeholder="+39 02 0000 0000" />
            </div>
          </div>
          <div class="contact__field">
            <label class="contact__label" for="cf-message">How can we help?</label>
            <textarea class="contact__textarea" id="cf-message" name="message" rows="5" required placeholder="Please describe your matter briefly. All information is treated as strictly confidential."></textarea>
          </div>
          {/* Honeypot — hidden from humans, spam bots will fill it. Server must reject submissions where this is non-empty. */}
          <div class="contact__honeypot" aria-hidden="true">
            <label for="cf-company-url">Do not fill this field.</label>
            <input type="text" id="cf-company-url" name="company_url" tabindex="-1" autocomplete="off" />
          </div>

          {gdprConsentLabel && (
            <label class="contact__consent">
              <input type="checkbox" name="gdpr_consent" required />
              <span set:html={
                privacyHref
                  ? gdprConsentLabel.replace('{privacy}', `<a href="${privacyHref}" target="_blank" rel="noopener noreferrer">privacy policy</a>`)
                  : gdprConsentLabel
              } />
            </label>
          )}

          <button class="contact__submit" type="submit">{submitLabel}</button>
        </form>
      </div>

      <div class="contact__info-col" data-animate>
        <div class="contact__office">
          <h3 class="contact__office-title display">{officeTitle}</h3>
          <address class="contact__address">
            <p>{site.contact.address}</p>
            <p>{site.contact.city}, Italy</p>
          </address>
          <div class="contact__details">
            {site.contact.phone && (
              <a class="contact__detail-link" href={`tel:${site.contact.phone.replace(/\s/g, '')}`}>
                <span class="contact__detail-label">Phone</span>
                <span>{site.contact.phone}</span>
              </a>
            )}
            <a class="contact__detail-link" href={`mailto:${site.contact.email}`}>
              <span class="contact__detail-label">Email</span>
              <span>{site.contact.email}</span>
            </a>
            {site.contact.lat && site.contact.lng && (
              <a
                class="contact__detail-link"
                href={`https://www.google.com/maps/search/?api=1&query=${site.contact.lat},${site.contact.lng}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="contact__detail-label">Directions</span>
                <span>Open in Maps &rarr;</span>
              </a>
            )}
          </div>
        </div>

        {confidentialityNote && (
          <div class="contact__note">
            <p>{confidentialityNote}</p>
          </div>
        )}

        {site.social.linkedin && (
          <a class="contact__linkedin" href={site.social.linkedin} target="_blank" rel="noopener noreferrer">
            Follow us on LinkedIn
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 860px) {
    .contact__grid { grid-template-columns: 1.2fr 0.8fr; }
  }

  .contact__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .contact__title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-md);
  }

  .contact__intro {
    font-size: var(--text-base);
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-xl);
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 480px) {
    .contact__row { grid-template-columns: 1fr 1fr; }
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .contact__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }

  .contact__input,
  .contact__textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-fg);
    outline: none;
    transition: border-color var(--duration-fast);
    resize: none;
  }

  .contact__input::placeholder,
  .contact__textarea::placeholder {
    color: var(--color-fg-faint);
  }

  .contact__input:focus,
  .contact__textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact__honeypot {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .contact__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
    cursor: pointer;
  }
  .contact__consent input[type="checkbox"] {
    margin-top: 0.2rem;
    flex-shrink: 0;
    accent-color: var(--color-accent);
  }
  .contact__consent a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .contact__submit {
    align-self: flex-start;
    padding: 0.875rem 2.5rem;
    background: var(--color-accent);
    color: white;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: background var(--duration-fast);
  }

  .contact__submit:hover {
    background: var(--color-accent-hover);
  }

  /* Info column */
  .contact__office {
    margin-bottom: var(--space-xl);
  }

  .contact__office-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-md);
  }

  .contact__address {
    font-style: normal;
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-lg);
  }

  .contact__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .contact__detail-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-fg);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--duration-fast);
  }

  .contact__detail-link:hover {
    color: var(--color-accent);
  }

  .contact__detail-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-fg-faint);
  }

  .contact__note {
    padding: var(--space-md);
    background: var(--color-accent-light);
    border-left: 3px solid var(--color-accent);
    margin-bottom: var(--space-lg);
  }

  .contact__note p {
    font-size: var(--text-sm);
    color: var(--color-accent);
    line-height: var(--leading-relaxed);
    font-style: italic;
  }

  .contact__linkedin {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-fg-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-strong);
    padding-bottom: 2px;
    transition: color var(--duration-fast), border-color var(--duration-fast);
  }

  .contact__linkedin:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
