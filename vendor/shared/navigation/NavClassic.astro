---
import type { NavLink } from '../../types/content';

interface Props {
  brandName: string;
  links: NavLink[];
  ctaLabel?: string;
  ctaHref?: string;
  logoHref?: string;
  /** Optional client logo image (path under public/, e.g. "/images/logo.png" or "/images/logo.svg"). When present, renders beside or in place of the text wordmark. */
  logoImage?: string;
  /** Rendered height of the logo image in pixels. Default 32. */
  logoHeight?: number;
  /** How to render the brand lockup: "image-only" shows just the logo, "image-and-text" shows both, "text-only" (default when no logoImage) shows the brandName only. */
  logoMode?: 'image-only' | 'image-and-text' | 'text-only';
}

const {
  brandName,
  links,
  ctaLabel,
  ctaHref = '#contact',
  logoHref = '/',
  logoImage,
  logoHeight = 32,
  logoMode = logoImage ? 'image-and-text' : 'text-only',
} = Astro.props;

// Prefix asset paths with Astro's base URL so assets resolve under GH Pages sub-path deploys.
const withBase = (p: string | undefined): string | undefined => {
  if (!p) return p;
  if (/^(https?:\/\/|data:)/.test(p)) return p;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return p.startsWith('/') ? `${base}${p}` : `${base}/${p}`;
};
---

<header class="nav" id="nav-classic" data-nav-classic>
  <div class="nav__inner container">
    <a href={logoHref} class="nav__brand display" aria-label={`${brandName} homepage`}>
      {logoImage && logoMode !== 'text-only' && (
        <img
          class="nav__brand-logo"
          src={withBase(logoImage)}
          alt={`${brandName} logo`}
          height={logoHeight}
          loading="eager"
          decoding="async"
          style={`height: ${logoHeight}px; width: auto;`}
        />
      )}
      {logoMode !== 'image-only' && (
        <span class="nav__brand-text">{brandName}</span>
      )}
    </a>

    <nav class="nav__links" aria-label="Main navigation">
      <ul class="nav__list">
        {links.map((link) => (
          <li class="nav__item">
            <a href={link.href} class="nav__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav__actions">
      {ctaLabel && (
        <a href={ctaHref} class="nav__cta">{ctaLabel}</a>
      )}

      <button
        class="nav__burger"
        id="nav-classic-burger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="nav-classic-overlay"
      >
        <span class="nav__burger-line"></span>
        <span class="nav__burger-line"></span>
        <span class="nav__burger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile fullscreen overlay -->
  <div
    class="nav__overlay"
    id="nav-classic-overlay"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
  >
    <nav class="nav__overlay-inner" aria-label="Mobile navigation">
      <ul class="nav__overlay-list">
        {links.map((link, i) => (
          <li class="nav__overlay-item" style={`--index: ${i}`}>
            <a href={link.href} class="nav__overlay-link display">{link.label}</a>
          </li>
        ))}
      </ul>
      {ctaLabel && (
        <a href={ctaHref} class="nav__overlay-cta">{ctaLabel}</a>
      )}
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    padding-block: var(--space-md);
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background 0.3s var(--ease-out),
      backdrop-filter 0.3s var(--ease-out),
      border-color 0.3s var(--ease-out),
      padding 0.3s var(--ease-out);
  }

  .nav.is-scrolled {
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
    border-bottom-color: var(--color-border);
    padding-block: var(--space-sm);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .nav__brand {
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-fg);
    text-decoration: none;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs, 0.5rem);
  }

  .nav__brand-logo {
    display: block;
    flex-shrink: 0;
  }

  .nav__brand-text {
    white-space: nowrap;
  }

  /* Desktop links */
  .nav__links {
    display: none;
    flex: 1;
    justify-content: center;
  }

  .nav__list {
    list-style: none;
    display: flex;
    gap: var(--space-lg);
    padding: 0;
    margin: 0;
  }

  .nav__link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-fg);
    text-decoration: none;
    padding-block: 4px;
    position: relative;
    transition: color 0.2s var(--ease-out);
  }

  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s var(--ease-out);
  }

  .nav__link:hover,
  .nav__link:focus-visible {
    color: var(--color-accent);
  }

  .nav__link:hover::after,
  .nav__link:focus-visible::after {
    transform: scaleX(1);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-shrink: 0;
  }

  .nav__cta {
    display: none;
    padding: 0.6em 1.4em;
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 100px;
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s var(--ease-out), transform 0.2s var(--ease-out);
  }

  .nav__cta:hover,
  .nav__cta:focus-visible {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  /* Burger */
  .nav__burger {
    position: relative;
    width: 32px;
    height: 24px;
    background: none;
    border: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: stretch;
    cursor: pointer;
    z-index: calc(var(--z-header) + 2);
    color: var(--color-fg);
  }

  .nav__burger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: currentColor;
    transition:
      transform 0.35s var(--ease-out),
      opacity 0.25s var(--ease-out);
  }

  .nav__burger[aria-expanded="true"] .nav__burger-line:nth-child(1) {
    transform: translateY(11px) rotate(45deg);
  }

  .nav__burger[aria-expanded="true"] .nav__burger-line:nth-child(2) {
    opacity: 0;
  }

  .nav__burger[aria-expanded="true"] .nav__burger-line:nth-child(3) {
    transform: translateY(-11px) rotate(-45deg);
  }

  @media (min-width: 768px) {
    .nav__links {
      display: flex;
    }

    .nav__cta {
      display: inline-flex;
    }

    .nav__burger {
      display: none;
    }
  }

  /* Overlay */
  .nav__overlay {
    position: fixed;
    inset: 0;
    z-index: calc(var(--z-header) + 1);
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s var(--ease-out);
  }

  .nav__overlay[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }

  .nav__overlay-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    padding: var(--space-xl);
    width: 100%;
  }

  .nav__overlay-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .nav__overlay-link {
    font-size: var(--text-display, var(--text-3xl));
    font-weight: 700;
    color: var(--color-fg);
    text-decoration: none;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.4s var(--ease-out),
      transform 0.4s var(--ease-out),
      color 0.2s var(--ease-out);
  }

  .nav__overlay[aria-hidden="false"] .nav__overlay-link {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--index, 0) * 0.06s + 0.1s);
  }

  .nav__overlay-link:hover,
  .nav__overlay-link:focus-visible {
    color: var(--color-accent);
  }

  .nav__overlay-cta {
    display: inline-flex;
    padding: 0.8em 2em;
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 100px;
    font-size: var(--text-base);
    font-weight: 600;
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease-out), background 0.2s var(--ease-out);
  }

  .nav__overlay[aria-hidden="false"] .nav__overlay-cta {
    opacity: 1;
    transition-delay: calc(var(--index, 0) * 0.06s + 0.35s);
  }

  .nav__overlay-cta:hover,
  .nav__overlay-cta:focus-visible {
    background: var(--color-accent-hover);
  }

  @media (min-width: 768px) {
    .nav__overlay {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav,
    .nav__link,
    .nav__link::after,
    .nav__cta,
    .nav__burger-line,
    .nav__overlay,
    .nav__overlay-link,
    .nav__overlay-cta {
      transition: none !important;
    }

    .nav__overlay-link {
      transform: none;
    }
  }
</style>

<script type="module">
  const nav = document.getElementById('nav-classic');
  const burger = document.getElementById('nav-classic-burger');
  const overlay = document.getElementById('nav-classic-overlay');

  if (nav && burger && overlay) {
    const overlayLinks = overlay.querySelectorAll('a');
    let lastFocus = null;

    const openMenu = () => {
      lastFocus = document.activeElement;
      overlay.setAttribute('aria-hidden', 'false');
      burger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      const firstLink = overlay.querySelector('a');
      if (firstLink) firstLink.focus();
    };

    const closeMenu = () => {
      overlay.setAttribute('aria-hidden', 'true');
      burger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      if (lastFocus && lastFocus.focus) {
        lastFocus.focus();
      } else {
        burger.focus();
      }
    };

    burger.addEventListener('click', () => {
      const isOpen = burger.getAttribute('aria-expanded') === 'true';
      if (isOpen) closeMenu();
      else openMenu();
    });

    overlayLinks.forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });

    // Scroll state
    let ticking = false;
    const updateScrollState = () => {
      nav.classList.toggle('is-scrolled', window.scrollY > 50);
      ticking = false;
    };

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(updateScrollState);
          ticking = true;
        }
      },
      { passive: true },
    );

    updateScrollState();
  }
</script>
