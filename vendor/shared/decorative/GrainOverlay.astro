---
/**
 * GrainOverlay — film-grain texture, fixed-position, pure CSS, no JS.
 *
 * Defaults are intentionally subtle (0.18 opacity, soft-light blend).
 * Earlier builds shipped with opacity 0.4 + overlay blend, which read as
 * "omnipresent texture" rather than "atmosphere" — see Denis's Krefer
 * feedback (2026-05-04). When in doubt, keep it under 0.22.
 *
 * Per-client overrides via CSS custom properties on :root:
 *   --grain-opacity (default 0.18)
 *   --grain-blend (default soft-light)
 *
 * Or pass props for one-shot overrides on a single page.
 */
interface Props {
  /** 0..1 — keep under 0.22 unless concept explicitly calls for heavy grain. */
  opacity?: number;
  /** CSS mix-blend-mode value. soft-light is gentle; overlay is loud. */
  blend?: string;
}

const { opacity, blend } = Astro.props as Props;
---

<div
  class="grain"
  aria-hidden="true"
  style={[
    opacity != null ? `--grain-opacity:${opacity}` : null,
    blend ? `--grain-blend:${blend}` : null,
  ].filter(Boolean).join(';')}
></div>

<style>
  .grain {
    position: fixed;
    inset: -100%;
    z-index: var(--z-decorative);
    pointer-events: none;
    opacity: var(--grain-opacity, 0.18);
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    animation: grain 8s steps(10) infinite;
    mix-blend-mode: var(--grain-blend, soft-light);
  }

  @keyframes grain {
    0%,100%   { transform: translate(0,0); }
    10%       { transform: translate(-5%,-10%); }
    20%       { transform: translate(-15%,5%); }
    30%       { transform: translate(7%,-25%); }
    40%       { transform: translate(-5%,25%); }
    50%       { transform: translate(-15%,10%); }
    60%       { transform: translate(15%,0%); }
    70%       { transform: translate(0%,15%); }
    80%       { transform: translate(3%,35%); }
    90%       { transform: translate(-10%,10%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .grain { animation: none; }
  }
</style>
