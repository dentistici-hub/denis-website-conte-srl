---
interface Props {
  tag?: 'div' | 'h1' | 'h2' | 'h3' | 'h4' | 'p' | 'span';
  class?: string;
  splitType?: 'chars' | 'words' | 'lines';
  stagger?: number;
  duration?: number;
  delay?: number;
}

const {
  tag = 'div',
  class: className = '',
  splitType = 'chars',
  stagger = 0.03,
  duration = 0.8,
  delay = 0,
} = Astro.props;
---

{tag === 'h1' && (
  <h1
    class:list={['split-reveal', className]}
    data-animate
    data-split-type={splitType}
    data-split-stagger={stagger}
    data-split-duration={duration}
    data-split-delay={delay}
  >
    <slot />
  </h1>
)}
{tag === 'h2' && (
  <h2
    class:list={['split-reveal', className]}
    data-animate
    data-split-type={splitType}
    data-split-stagger={stagger}
    data-split-duration={duration}
    data-split-delay={delay}
  >
    <slot />
  </h2>
)}
{tag === 'h3' && (
  <h3
    class:list={['split-reveal', className]}
    data-animate
    data-split-type={splitType}
    data-split-stagger={stagger}
    data-split-duration={duration}
    data-split-delay={delay}
  >
    <slot />
  </h3>
)}
{tag === 'h4' && (
  <h4
    class:list={['split-reveal', className]}
    data-animate
    data-split-type={splitType}
    data-split-stagger={stagger}
    data-split-duration={duration}
    data-split-delay={delay}
  >
    <slot />
  </h4>
)}
{tag === 'p' && (
  <p
    class:list={['split-reveal', className]}
    data-animate
    data-split-type={splitType}
    data-split-stagger={stagger}
    data-split-duration={duration}
    data-split-delay={delay}
  >
    <slot />
  </p>
)}
{tag === 'span' && (
  <span
    class:list={['split-reveal', className]}
    data-animate
    data-split-type={splitType}
    data-split-stagger={stagger}
    data-split-duration={duration}
    data-split-delay={delay}
  >
    <slot />
  </span>
)}
{tag === 'div' && (
  <div
    class:list={['split-reveal', className]}
    data-animate
    data-split-type={splitType}
    data-split-stagger={stagger}
    data-split-duration={duration}
    data-split-delay={delay}
  >
    <slot />
  </div>
)}
