---
import type { Testimonial } from '../../types/content';

interface Props {
  testimonials: Testimonial[];
  sectionTitle?: string;
}

const { testimonials, sectionTitle = 'What Clients Say' } = Astro.props;
---

<section class="testimonials section" aria-labelledby="testimonials-title">
  <div class="container">
    <div class="testimonials__header" data-animate>
      <p class="testimonials__eyebrow">Client Feedback</p>
      <h2 class="testimonials__title display" id="testimonials-title">{sectionTitle}</h2>
    </div>

    <div class="testimonials__grid">
      {testimonials.map((item, i) => (
        <blockquote class="testimonials__card" data-animate style={`--index: ${i}`}>
          <div class="testimonials__mark" aria-hidden="true">"</div>
          <p class="testimonials__quote">{item.quote}</p>
          <footer class="testimonials__footer">
            <p class="testimonials__author">{item.author}</p>
            <p class="testimonials__company">{[item.role, item.company].filter(Boolean).join(', ')}</p>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--color-bg-card);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .testimonials__header {
    max-width: 600px;
    margin-bottom: var(--space-xl);
  }

  .testimonials__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .testimonials__title {
    font-size: var(--text-3xl);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .testimonials__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .testimonials__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .testimonials__card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    position: relative;
  }

  .testimonials__mark {
    font-family: var(--font-display);
    font-size: clamp(4rem, 2rem + 5vw, 7rem);
    color: var(--color-accent);
    opacity: 0.15;
    line-height: 0.6;
    pointer-events: none;
    user-select: none;
  }

  .testimonials__quote {
    font-size: var(--text-base);
    color: var(--color-fg);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  .testimonials__footer {
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonials__author {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-fg);
    font-style: normal;
  }

  .testimonials__company {
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
    font-style: italic;
  }
</style>
